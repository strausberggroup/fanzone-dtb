---
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/01-Header.astro';
import Footer from '../components/sections/14-Footer.astro';
import checkInPhoto from '../assets/images/13-be-part-of-action/group-stroll.jpg';
import culinaryPhoto from '../assets/images/10-dine-drink/friends-laughing-dinner.jpg';

const ticketUrl = 'https://tickets.cbfproductions.com/e/los-angeles-world-cup-26-fan-zone-downtown-burbank?utm_source=fanzone-dtb&utm_medium=info-cta&utm_campaign=worldcup26';

const accessRows = [
	{
		ticket: 'Culinary Experience',
		color: 'coral',
		cells: ['✓', '✓', '—', '—', '—'],
	},
	{
		ticket: 'Passport Lounge',
		color: 'blue',
		cells: ['✓', '—', '✓ (all 3)', '—', '—'],
	},
	{
		ticket: 'Concert Experience + GA Watch Party',
		color: 'purple',
		cells: ['✓', '—', '—', '✓', '—'],
	},
	{
		ticket: 'GA Watch Party',
		color: 'pink',
		cells: ['✓', '—', '—', '—', '✓'],
	},
];

const accessCols = [
	'International Street Fair',
	'Culinary Terrace',
	'Passport Lounges',
	'Concert Watch Party',
	'GA Watch Party',
];

const checkIns = [
	{
		color: 'coral',
		name: 'Culinary Experience with Celebrity Chef Geoffrey Zakarian',
		address: '201 E. Magnolia Blvd.',
		note: 'Enter on the escalator at the intersection of Magnolia Blvd. and San Fernando Blvd.',
	},
	{
		color: 'blue',
		name: 'Passport Lounges',
		address: 'Three locations — check in at any of them:',
		list: [
			'#1 (Orange Grove North) — 209 E. Orange Grove Ave.',
			'#2 (Orange Grove South) — 198 E. Orange Grove Ave.',
			'#3 (San Fernando) — 100 S. San Fernando Blvd.',
		],
	},
	{
		color: 'purple',
		name: 'Concert Experience + GA Watch Party',
		address: '211 E. Olive Ave.',
	},
	{
		color: 'pink',
		name: 'General Admission Watch Party',
		address: '175 E. Olive Ave.',
	},
];

const faqs = [
	{
		q: 'What are the hours?',
		a: `<p>Saturday, July 18: 12 PM – 8 PM<br />Sunday, July 19: 10 AM – 6 PM</p>`,
	},
	{
		q: 'Does my ticket include the concert?',
		a: `
			<p>Only the <strong>Concert Experience + GA Watch Party</strong> ticket includes access to the live concert on Olive Ave. north of San Fernando Blvd. (entrance near 211 E. Olive Ave.). Concert capacity is limited — book early if this matters to you.</p>
			<ul>
				<li><strong>GA Watch Party</strong> — concert is live-streamed to the big screen in your area on Olive Ave. south of San Fernando Blvd.</li>
				<li><strong>Passport Lounge</strong> and <strong>Culinary Experience</strong> — no concert access (live or streaming) without a separate ticket.</li>
			</ul>
		`,
	},
	{
		q: 'Which ticket should I choose?',
		a: `
			<ul>
				<li><strong>Culinary Experience with Celebrity Chef Geoffrey Zakarian</strong> — best for a premium, limited-capacity experience with food, drinks, lounge seating, and live match viewing.</li>
				<li><strong>Passport Lounge</strong> — ideal if you want to explore multiple themed lounges and move around.</li>
				<li><strong>Concert Experience + GA Watch Party</strong> — the full experience: match plus live concert.</li>
				<li><strong>GA Watch Party</strong> — the most affordable way to join the main fan atmosphere.</li>
			</ul>
			<p>If you want the concert, make sure you select the <strong>Concert Experience + GA Watch Party</strong> ticket.</p>
		`,
	},
	{
		q: "What's included in the Culinary Experience?",
		a: `
			<p>Culinary Experience guests enjoy a fully elevated experience:</p>
			<ul>
				<li>Unlimited food + drink pairings (Sat. July 18: 12 PM – 3 PM | Sun. July 19: 10 AM – 1 PM)</li>
				<li>Live cooking demo by Celebrity Chef Geoffrey Zakarian</li>
				<li>Private terrace with seating, shade, and premium match viewing with full sound</li>
				<li>Both alcoholic and non-alcoholic beverages are included</li>
				<li>Vegan/vegetarian options are not guaranteed — additional food is available for purchase outside the Culinary Experience Terrace</li>
				<li>After 3 PM Saturday and 1 PM Sunday, a full bar remains open with drinks for purchase</li>
			</ul>
			<p>This is the only ticket that includes food and beverage.</p>
		`,
	},
	{
		q: 'Will there be seating?',
		a: `
			<ul>
				<li><strong>Culinary Experience &amp; Passport Lounges</strong> — lounge-style communal seating, first come, first served.</li>
				<li><strong>GA Watch Party</strong> — communal seating available, but not guaranteed.</li>
			</ul>
			<p>Arriving early is the best way to secure a preferred spot.</p>
		`,
	},
	{
		q: 'When should I arrive?',
		a: `
			<ul>
				<li>Arrive early for the best viewing locations, especially for GA tickets.</li>
				<li>Culinary Experience guests should arrive closer to 12 PM on Saturday and 10 AM on Sunday to enjoy the full experience.</li>
			</ul>
			<p>Late arrival is allowed, but premium spots may be taken.</p>
		`,
	},
	{
		q: 'Can I leave and come back?',
		a: `<p>Yes — in &amp; outs are allowed with your wristband. Just make sure you don't remove or lose your wristband, or re-entry will not be permitted.</p>`,
	},
	{
		q: 'Can I upgrade my ticket?',
		a: `<p>Limited upgrades may be available at the entrance to each area, while supplies last. For the best experience, we recommend purchasing the ticket you want in advance.</p>`,
	},
	{
		q: 'Where should I park?',
		a: `<p>There is no designated event parking, but there are multiple nearby garages and lots in Downtown Burbank. We recommend arriving early to allow time for parking and walking to your check-in location. See the <a href="https://dtnbur.com/parking/" target="_blank" rel="noopener noreferrer">Downtown Burbank parking map</a> for details.</p>`,
	},
	{
		q: 'Will food and drinks be available?',
		a: `
			<ul>
				<li><strong>Culinary Experience</strong> — included (Saturday: 12 PM – 3 PM | Sunday: 10 AM – 1 PM).</li>
				<li><strong>All other tickets</strong> — food and beverages available for purchase. See the event map for food locations.</li>
			</ul>
			<p>No outside alcohol is permitted.</p>
		`,
	},
	{
		q: 'Is the event all ages?',
		a: `
			<p>Yes, but:</p>
			<ul>
				<li>You must be 21+ with valid ID to enter the Culinary Experience Terrace.</li>
				<li>You must be 21+ with valid ID to purchase alcohol.</li>
			</ul>
		`,
	},
	{
		q: 'What happens if it rains?',
		a: `<p>The event is rain or shine and all sales are final.</p>`,
	},
	{
		q: 'What do I need to enter?',
		a: `
			<ul>
				<li>A valid, scannable ticket — no screenshots.</li>
				<li>Check in at your assigned location to receive your wristband.</li>
				<li><strong>Culinary Experience only</strong> — 21+ with valid ID.</li>
			</ul>
		`,
	},
	{
		q: 'Can I access other areas of the event?',
		a: `
			<p>All ticket holders can enjoy the International Street Fair and Activations on San Fernando Blvd. between Magnolia Blvd. and Olive Ave. Access to the Culinary Experience, Passport Lounges, and Watch Party areas depends on your ticket type.</p>
			<p>Passport Lounge ticket holders can move freely between all three Passport Lounges. General Admission Watch Party ticket holders (with and without the Concert Experience) have designated Watch Party areas — you cannot enter the other GA Watch Party area without purchasing a separate ticket.</p>
		`,
	},
	{
		q: 'Is my ticket valid for both Saturday and Sunday?',
		a: `<p>Your ticket is valid for one day only. To attend both days, you need to purchase separate tickets. If you can't attend on the day you purchased, the ticket cannot be used on another day.</p>`,
	},
	{
		q: 'Will there be security checkpoints?',
		a: `<p>The Los Angeles World Cup 26 Fan Zone at Downtown Burbank will have a large security and police presence. All guests entering the area are subject to bag checks and metal detector screening.</p>`,
	},
	{
		q: "What's the overall experience like?",
		a: `
			<p>Expect a high-energy, festival-style World Cup celebration with:</p>
			<ul>
				<li>Massive LED screens and full sound</li>
				<li>Thousands of fans</li>
				<li>Food, drinks, activations, and an International Street Fair throughout Downtown Burbank</li>
			</ul>
			<p>This is designed to be a historic, memorable, city-wide event.</p>
		`,
	},
];
---

<Layout title="Know Before You Go | Fan Zone at Downtown Burbank" description="Hours, parking, check-in, ticket access, game schedule, FAQs and rules for the Los Angeles World Cup 26 Fan Zone at Downtown Burbank, July 18–19.">
	<Header />

	<div class="info-buffer"></div>

	<section class="info-hero">
		<div class="info-hero__inner">
			<p class="info-hero__eyebrow">Los Angeles World Cup 26 Fan Zone at Downtown Burbank</p>
			<h1 class="info-hero__title">Know Before You Go</h1>
			<p class="info-hero__dates">Saturday, July 18 · 12 PM – 8 PM<br />Sunday, July 19 · 10 AM – 6 PM</p>
		</div>
	</section>

	<main class="info-main">

		<!-- Hours & Location: solid coral block -->
		<section id="info" class="hours">
			<div class="hours__inner">
				<div class="hours__cell">
					<p class="hours__label">Saturday, July 18</p>
					<p class="hours__value">12 PM – 8 PM</p>
					<p class="hours__note">Bronze Final</p>
				</div>
				<div class="hours__cell">
					<p class="hours__label">Sunday, July 19</p>
					<p class="hours__value">10 AM – 6 PM</p>
					<p class="hours__note">World Cup Final</p>
				</div>
				<div class="hours__cell">
					<p class="hours__label">Where</p>
					<p class="hours__value">Downtown Burbank</p>
					<p class="hours__note">San Fernando Blvd. between Magnolia Blvd. and Angeleno Ave.</p>
				</div>
			</div>
		</section>

		<!-- Parking -->
		<section id="parking" class="info-section">
			<div class="info-section__inner">
				<h2 class="info-section__heading">Parking</h2>
				<p>There is no designated parking area for this event. See the City of Burbank's parking map for all nearby lots and structures. The red "Paid Street Parking" sections on the map will not be available during the event.</p>
				<p>We recommend arriving early to allow time for parking and walking to your check-in location.</p>
				<p class="info-section__cta-row">
					<a href="https://dtnbur.com/parking/" target="_blank" rel="noopener noreferrer" class="info-button info-button--outline">Parking Map &amp; Directions<span class="sr-only"> (opens in new window)</span></a>
				</p>
			</div>
		</section>

		<!-- Check-In: photo banner + 2x2 saturated cards -->
		<section id="check-in" class="info-section">
			<div class="info-section__inner">
				<h2 class="info-section__heading">Check-In</h2>
				<p>Each ticket level has a different outdoor check-in location. Your tickets and order confirmation will tell you which location to use. <strong>You must check in at your assigned location</strong> — you cannot check in at the other locations within the Fan Zone. Passport Lounge ticket holders can check in at any of the three Passport Lounge locations.</p>

				<div class="check-in__photo">
					<img src={checkInPhoto.src} alt="Fans walking through Downtown Burbank" width="1150" />
				</div>

				<div class="check-in__grid">
					{checkIns.map(c => (
						<div class={`check-in__card check-in__card--${c.color}`}>
							<h3 class="check-in__name">{c.name}</h3>
							<p class="check-in__address">{c.address}</p>
							{c.list && (
								<ul class="check-in__list">
									{c.list.map(item => <li>{item}</li>)}
								</ul>
							)}
							{c.note && <p class="check-in__note">{c.note}</p>}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Ticket Access -->
		<section id="access" class="info-section">
			<div class="info-section__inner">
				<h2 class="info-section__heading">Area Access by Ticket Type</h2>
				<p>All ticket types have access to the <strong>International Street Fair and Activations</strong> on San Fernando Blvd. between Magnolia Blvd. and Olive Ave. Access to the other areas depends on your ticket.</p>

				<div class="access-table-wrap" role="region" aria-label="Ticket access matrix" tabindex="0">
					<table class="access-table">
						<thead>
							<tr>
								<th scope="col">Ticket</th>
								{accessCols.map(c => <th scope="col">{c}</th>)}
							</tr>
						</thead>
						<tbody>
							{accessRows.map(r => (
								<tr>
									<th scope="row">{r.ticket}</th>
									{r.cells.map((cell, i) => {
										const isNo = cell === '—';
										return (
											<td data-label={accessCols[i]}>
												{isNo ? (
													<span class="access-mark access-mark--no" aria-label="Not included">—</span>
												) : (
													<span class="access-mark-row">
														<span class="access-mark access-mark--yes" aria-label="Included">✓</span>
														{cell !== '✓' && <span class="access-mark__extra">{cell.replace('✓ ', '')}</span>}
													</span>
												)}
											</td>
										);
									})}
								</tr>
							))}
						</tbody>
					</table>
				</div>

				<div class="access-cards">
					{accessRows.map(r => (
						<div class={`access-card access-card--${r.color}`}>
							<h3 class="access-card__ticket">{r.ticket}</h3>
							<ul class="access-card__list">
								{r.cells.map((cell, i) => (
									<li class={cell === '—' ? 'access-card__no' : 'access-card__yes'}>
										<span class="access-card__mark" aria-hidden="true">{cell}</span>
										<span>{accessCols[i]}</span>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Map: full-bleed, no caption -->
		<section class="info-map" aria-label="Fan Zone layout map">
			<div class="info-map__inner">
				<img src="/images/dtb-map.webp" alt="Fan Zone layout map for the Los Angeles World Cup 26 Fan Zone at Downtown Burbank. The International Street Fair runs along San Fernando Blvd. between Magnolia Blvd. and Olive Ave. The Culinary Experience Terrace sits at Burbank Town Center on Magnolia Blvd. Three Passport Lounges sit on Orange Grove Ave. and San Fernando Blvd. The Concert Experience + GA Watch Party occupies Olive Ave. north of San Fernando Blvd., and the General Admission Watch Party occupies Olive Ave. south of San Fernando Blvd." width="1440" />
			</div>
		</section>

		<!-- Games: two big saturated cards -->
		<section id="games" class="info-section">
			<div class="info-section__inner">
				<h2 class="info-section__heading">Guide to the Games</h2>
				<div class="games__grid">
					<article class="game-card game-card--blue">
						<p class="game-card__day">Saturday, July 18</p>
						<h3 class="game-card__title">Bronze Final</h3>
						<p class="game-card__teams">Teams TBD by tournament play</p>
						<dl class="game-card__schedule">
							<div><dt>Event Hours</dt><dd>12 PM – 8 PM</dd></div>
							<div><dt>Pregame</dt><dd>1:00 PM PST</dd></div>
							<div><dt>Kick Off</dt><dd>2:00 PM PST</dd></div>
						</dl>
					</article>
					<article class="game-card game-card--coral">
						<p class="game-card__day">Sunday, July 19</p>
						<h3 class="game-card__title">World Cup Final</h3>
						<p class="game-card__teams">Teams TBD by tournament play</p>
						<dl class="game-card__schedule">
							<div><dt>Event Hours</dt><dd>10 AM – 6 PM</dd></div>
							<div><dt>Pregame</dt><dd>10:00 AM PST</dd></div>
							<div><dt>Kick Off</dt><dd>12:00 PM PST</dd></div>
							<div><dt>Half-Time Show</dt><dd>15–20 minutes</dd></div>
						</dl>
					</article>
				</div>
			</div>
		</section>

		<!-- Programming: photo + saturated blocks side-by-side -->
		<section id="programming" class="info-section">
			<div class="info-section__inner">
				<h2 class="info-section__heading">Culinary Experience &amp; Post-Match Concert</h2>

				<div class="programming__layout">
					<div class="programming__photo">
						<img src={culinaryPhoto.src} alt="Friends sharing a meal" width="500" />
					</div>
					<div class="programming__blocks">
						<article class="programming-block programming-block--purple">
							<h3 class="programming-block__title">Culinary Experience with Celebrity Chef Geoffrey Zakarian</h3>
							<p class="programming-block__hours"><strong>Saturday:</strong> 12 PM – 3 PM &nbsp;·&nbsp; <strong>Sunday:</strong> 10 AM – 1 PM</p>
							<p>Live cooking demonstration and unlimited food and drink pairings curated by the chef on our Culinary Experience Terrace overlooking Downtown Burbank, with lounge seating, cocktail tables, and shade. Includes a large LED screen with full sound for the ultimate match viewing experience. After 3 PM on Saturday and 1 PM on Sunday, the Culinary Experience Terrace remains open with a full bar for you to enjoy the remainder of the match.</p>
						</article>

						<article class="programming-block programming-block--coral">
							<h3 class="programming-block__title">Post-Match Concert</h3>
							<p>After the final whistle, a live concert by a nationally touring artist (to be announced) takes the stage in the Watch Party area on Olive Ave. north of San Fernando Blvd. (enter at 211 E. Olive Ave.). You must have the <strong>Concert Experience + GA Watch Party</strong> ticket to enter this area — tickets are limited.</p>
							<p>The concert will also be live-streamed to the big screen in the other Watch Party area on Olive Ave. south of San Fernando Blvd. (enter at 175 E. Olive Ave.).</p>
						</article>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQs -->
		<section id="faqs" class="info-section info-section--tan">
			<div class="info-section__inner">
				<h2 class="info-section__heading info-section__heading--blue">FAQs</h2>
				<p>Common questions about access, food, hours, and the concert.</p>
				<div class="faqs">
					{faqs.map(f => (
						<details class="faq">
							<summary class="faq__q">
								<span>{f.q}</span>
								<span class="faq__arrow" aria-hidden="true">→</span>
							</summary>
							<div class="faq__a" set:html={f.a}></div>
						</details>
					))}
				</div>
			</div>
		</section>

		<!-- Rules -->
		<section id="rules" class="info-section">
			<div class="info-section__inner">
				<h2 class="info-section__heading info-section__heading--purple">Rules</h2>
				<p>Event rules and prohibited items — please read before you arrive.</p>

				<div class="rules">
					<p>There are absolutely <strong>no refunds</strong> for any reason and this event is rain or shine.</p>
					<p>In &amp; outs are permitted as long as you have a Fan Zone-issued wristband, which you receive when you check in. If your wristband is lost or removed, you will not be able to re-enter the Passport Lounges or Watch Party areas without purchasing another ticket.</p>
					<p>No alcohol is allowed outside of the Culinary Experience Terrace, the Passport Lounges, or the General Admission Watch Party areas.</p>
					<p>You must have a valid, government-issued ID to purchase alcohol or to enter the Culinary Experience Terrace.</p>
					<p>You must provide valid, scannable tickets to enter the Culinary Experience Terrace, the Passport Lounges, or the General Admission Watch Party areas. Screenshots are not considered valid.</p>
				</div>

				<div class="prohibited">
					<div class="prohibited__col prohibited__col--pink">
						<h3 class="prohibited__heading">Prohibited Activities</h3>
						<ul>
							<li>Moshing</li>
							<li>Crowd surfing</li>
							<li>Stage diving</li>
							<li>Nudity or exposed body parts (prohibited under California County Code §32.1002)</li>
						</ul>
					</div>
					<div class="prohibited__col prohibited__col--blue">
						<h3 class="prohibited__heading">Prohibited Items</h3>
						<ul>
							<li>Weapons or firearms, including pocket knives (including off-duty law enforcement)</li>
							<li>Cans, bottles, glass containers, or coolers</li>
							<li>CamelBaks or hydration bladders</li>
							<li>Illegal drugs or drug paraphernalia</li>
							<li>Professional photo or video recording equipment</li>
							<li>Skateboards, bicycles, or motorized vehicles</li>
							<li>Footballs, baseballs, frisbees, or playing catch</li>
							<li>Gang-related colors or insignia</li>
							<li>Drones</li>
							<li>Fireworks or explosives</li>
							<li>Laser pointers or selfie sticks</li>
							<li>Stickers, flyers, or unauthorized solicitations</li>
							<li>Pets — prohibited in the Culinary Experience Terrace, Passport Lounges, and Watch Party areas. Service animals permitted under ADA regulations.</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Bottom CTA: coral with animated dot canvas (mirrors Hero) -->
		<section class="info-cta">
			<canvas id="info-cta-dots" class="info-cta__canvas"></canvas>
			<div class="info-cta__inner">
				<h2 class="info-cta__heading">Ready to Join Us?</h2>
				<p class="info-cta__text">Pick your ticket and secure your spot at the Los Angeles World Cup 26 Fan Zone at Downtown Burbank.</p>
				<a href={ticketUrl} target="_blank" rel="noopener noreferrer" class="info-cta__btn">Get Tickets</a>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<script>
	function initCtaDots() {
		const canvas = document.getElementById('info-cta-dots') as HTMLCanvasElement;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const BG = '#FF5252';
		const DOT_COLOR = '#f63d59';
		const RING_COLOR = '#fb9765';
		const DOT_RADIUS = 10;
		const RING_THICKNESS = 6;
		const SPACING = 60;

		let cols = 0;
		let rows = 0;
		let animId: number;

		function resize() {
			const section = canvas.parentElement!;
			const dpr = window.devicePixelRatio || 1;
			const w = section.offsetWidth;
			const h = section.offsetHeight;
			canvas.width = w * dpr;
			canvas.height = h * dpr;
			canvas.style.width = w + 'px';
			canvas.style.height = h + 'px';
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
			cols = Math.ceil(w / SPACING) + 1;
			rows = Math.ceil(h / SPACING) + 1;
		}

		interface Pulse {
			cx: number;
			cy: number;
			birth: number;
			duration: number;
			reach: number;
		}

		const pulses: Pulse[] = [];
		const PULSE_INTERVAL = 3000;
		const PULSE_DURATION = 4500;
		const PULSE_REACH = 350;
		let lastPulseTime = -PULSE_INTERVAL;

		function spawnPulse(time: number) {
			pulses.push({
				cx: 0.1 + Math.random() * 0.8,
				cy: 0.1 + Math.random() * 0.8,
				birth: time,
				duration: PULSE_DURATION + Math.random() * 1500,
				reach: PULSE_REACH + Math.random() * 100,
			});
			while (pulses.length > 4) {
				pulses.shift();
			}
		}

		function draw(time: number) {
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;

			ctx!.fillStyle = BG;
			ctx!.fillRect(0, 0, w, h);

			if (time - lastPulseTime > PULSE_INTERVAL) {
				spawnPulse(time);
				lastPulseTime = time;
			}

			const offsetX = ((w % SPACING) / 2);
			const offsetY = ((h % SPACING) / 2);

			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					const x = offsetX + c * SPACING;
					const y = offsetY + r * SPACING;

					let bestAlpha = 0;
					let bestScale = 1;

					for (const p of pulses) {
						const age = time - p.birth;
						if (age < 0 || age > p.duration) continue;

						const pcx = p.cx * w;
						const pcy = p.cy * h;
						const dist = Math.sqrt((x - pcx) ** 2 + (y - pcy) ** 2);

						if (dist > p.reach) continue;

						const proximity = 1 - dist / p.reach;
						const progress = age / p.duration;
						const breathe = Math.sin(progress * Math.PI);

						const alpha = proximity * breathe;
						if (alpha > bestAlpha) {
							bestAlpha = alpha;
							bestScale = 1 + 0.6 * alpha;
						}
					}

					if (bestAlpha > 0.05) {
						const dotR = DOT_RADIUS * bestScale;
						const ringR = dotR + RING_THICKNESS * bestAlpha;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR + (ringR - dotR) / 2, 0, Math.PI * 2);
						ctx!.strokeStyle = RING_COLOR;
						ctx!.globalAlpha = bestAlpha;
						ctx!.lineWidth = ringR - dotR;
						ctx!.stroke();
						ctx!.globalAlpha = 1;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					} else {
						ctx!.beginPath();
						ctx!.arc(x, y, DOT_RADIUS, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					}
				}
			}

			lastDrawTime = time;
			animId = requestAnimationFrame(draw);
		}

		let lastDrawTime = 0;

		const section = canvas.parentElement!;
		const ro = new ResizeObserver(() => {
			resize();
			draw(lastDrawTime);
		});
		ro.observe(section);

		resize();

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReducedMotion) {
			draw(0);
			cancelAnimationFrame(animId!);
		} else {
			let isVisible = false;
			const io = new IntersectionObserver(([entry]) => {
				isVisible = entry.isIntersecting;
				if (isVisible) {
					animId = requestAnimationFrame(draw);
				} else {
					cancelAnimationFrame(animId);
				}
			}, { threshold: 0 });
			io.observe(section);
		}
	}

	document.addEventListener('astro:page-load', initCtaDots);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initCtaDots);
	} else {
		initCtaDots();
	}
</script>

