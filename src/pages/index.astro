---
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/01-Header.astro';
import Hero from '../components/sections/02-Hero.astro';
import About from '../components/sections/03-About.astro';
import Countdown from '../components/sections/04-Countdown.astro';
import NoTickets from '../components/sections/05-NoTickets.astro';
import VipTicket from '../components/sections/06-VipTicket.astro';
import GetInvolved from '../components/sections/07-GetInvolved.astro';
import GettingHere from '../components/sections/08-GettingHere.astro';
import StreetFair from '../components/sections/09-StreetFair.astro';
import DineDrink from '../components/sections/10-DineDrink.astro';
import StayHere from '../components/sections/11-StayHere.astro';
import WhatIsFanZone from '../components/sections/12-WhatIsFanZone.astro';
import BePartOfAction from '../components/sections/13-BePartOfAction.astro';
import OurMoment from '../components/sections/13b-OurMoment.astro';
import PlanYourVisit from '../components/sections/13c-PlanYourVisit.astro';
import ThingsToDoBurbank from '../components/sections/15-ThingsToDoBurbank.astro';
import Footer from '../components/sections/14-Footer.astro';
import FloatingTicketsCta from '../components/FloatingTicketsCta.astro';

const ticketUrl = 'https://tickets.cbfproductions.com/e/los-angeles-world-cup-26-fan-zone-downtown-burbank?utm_source=fanzone-dtb&utm_medium=floating-cta&utm_campaign=worldcup26';
---

<Layout title="FanZone | Downtown Burbank">
	<Header />
	<Hero />
	<About />
	<Countdown />
	<NoTickets />
	<VipTicket />
	<GetInvolved />
	<GettingHere />
	<StreetFair />
	<DineDrink />
	<StayHere />
	<WhatIsFanZone />
	<BePartOfAction />
	<ThingsToDoBurbank />
	<OurMoment />
	<PlanYourVisit />
	<FloatingTicketsCta href={ticketUrl} showAfter=".hero" hideOn=".footer" />
	<Footer />
</Layout>
