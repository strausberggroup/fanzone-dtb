---
import photo from '../../assets/images/10-dine-drink/friends-laughing-dinner.jpg';
---

<section class="dine-drink">
	<canvas id="dine-drink-dots" class="dine-drink__canvas"></canvas>
	<div class="dine-drink__inner">
		<div class="dine-drink__content">
			<h2 class="dine-drink__heading">Dine. Drink. <br>Celebrate All Day.</h2>

			<p class="dine-drink__text">The party doesn't stop at the Fan Zone gates.</p>

			<p class="dine-drink__text">Downtown Burbank's restaurants and bars will be serving up match-day specials, global-inspired menus, themed cocktails, and extended viewing celebrations throughout the tournament.</p>

			<ul class="dine-drink__list">
				<li>Grab tacos before kickoff</li>
				<li>Celebrate with champagne after a win</li>
				<li>Keep the party going long after the final whistle</li>
			</ul>

			<a href="https://dtnbur.com/dine/" class="dine-drink__btn">Explore Our Restaurants</a>
		</div>

		<div class="dine-drink__image">
			<img src={photo.src} alt="Friends laughing and enjoying cocktails at a restaurant" width="500" height="500" />
		</div>
	</div>
</section>

<style>
	.dine-drink {
		background-color: #5DC19B;
		color: white;
		padding: 7rem 2rem;
		position: relative;
		overflow: hidden;
	}

	.dine-drink__canvas {
		position: absolute;
		top: 0;
		right: 0;
		width: 40%;
		height: 100%;
		pointer-events: none;
	}

	.dine-drink__inner {
		max-width: 1150px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 4rem;
		position: relative;
		z-index: 1;
	}

	.dine-drink__content {
		flex: 1;
	}

	.dine-drink__image {
		flex: 0 0 42%;
	}

	.dine-drink__image img {
		width: 100%;
		height: auto;
		border-radius: 16px;
		display: block;
	}

	.dine-drink__heading {
		font-family: var(--font-family);
		font-size: clamp(1.8rem, 3.5vw, 45px);
		font-weight: 700;
		text-transform: uppercase;
		line-height: 1.15;
		margin: 0 0 1.5rem;
		color: var(--color-dark);
	}

	.dine-drink__text {
		font-family: var(--font-family);
		font-size: 16px;
		font-weight: 400;
		line-height: 1.6;
		margin: 0 0 0.75em;
		color: var(--color-dark);
	}

	.dine-drink__list {
		font-family: var(--font-family);
		font-size: 16px;
		font-weight: 400;
		line-height: 1.8;
		margin: 0 0 2rem;
		padding-left: 1.25rem;
		color: var(--color-dark);
	}

	.dine-drink__list li::marker {
		font-size: 0.75em;
	}

	.dine-drink__btn {
		display: inline-block;
		background-color: var(--color-coral);
		color: white;
		font-family: var(--font-family);
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.75rem 2rem;
		border-radius: 4px;
		text-decoration: none;
		transition: filter 0.3s;
	}

	.dine-drink__btn:hover {
		filter: brightness(1.1);
	}

	@media (max-width: 768px) {
		.dine-drink__inner {
			flex-direction: column;
			gap: 2rem;
		}

		.dine-drink__image {
			flex: none;
			width: 100%;
		}
	}
</style>

<script>
	function initDineDrinkDots() {
		const canvas = document.getElementById('dine-drink-dots') as HTMLCanvasElement;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const BG = '#7EAE97';
		const DOT_COLOR = '#6B9E88';
		const RING_COLOR = '#A2D4B8';
		const DOT_RADIUS = 10;
		const RING_THICKNESS = 6;
		const SPACING = 60;

		let cols = 0;
		let rows = 0;
		let animId: number;

		function resize() {
			const dpr = window.devicePixelRatio || 1;
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;
			canvas.width = w * dpr;
			canvas.height = h * dpr;
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
			cols = Math.ceil(w / SPACING) + 1;
			rows = Math.ceil(h / SPACING) + 1;
		}

		interface Pulse {
			cx: number;
			cy: number;
			birth: number;
			duration: number;
			reach: number;
		}

		const pulses: Pulse[] = [];
		const PULSE_INTERVAL = 6000;
		const PULSE_DURATION = 8000;
		const PULSE_REACH = 300;
		let lastPulseTime = -PULSE_INTERVAL;

		function spawnPulse(time: number) {
			pulses.push({
				cx: 0.1 + Math.random() * 0.8,
				cy: 0.45 + Math.random() * 0.5,
				birth: time,
				duration: PULSE_DURATION + Math.random() * 1500,
				reach: PULSE_REACH + Math.random() * 100,
			});
			while (pulses.length > 4) {
				pulses.shift();
			}
		}

		function draw(time: number) {
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;

			ctx!.fillStyle = BG;
			ctx!.fillRect(0, 0, w, h);

			if (time - lastPulseTime > PULSE_INTERVAL) {
				spawnPulse(time);
				lastPulseTime = time;
			}

			const offsetX = ((w % SPACING) / 2);
			const offsetY = ((h % SPACING) / 2);

			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					const x = offsetX + c * SPACING;
					const y = offsetY + r * SPACING;

					let bestAlpha = 0;
					let bestScale = 1;

					for (const p of pulses) {
						const age = time - p.birth;
						if (age < 0 || age > p.duration) continue;

						const pcx = p.cx * w;
						const pcy = p.cy * h;
						const dist = Math.sqrt((x - pcx) ** 2 + (y - pcy) ** 2);

						if (dist > p.reach) continue;

						const proximity = 1 - dist / p.reach;
						const progress = age / p.duration;
						const breathe = Math.sin(progress * Math.PI);

						const alpha = proximity * breathe;
						if (alpha > bestAlpha) {
							bestAlpha = alpha;
							bestScale = 1 + 0.4 * alpha;
						}
					}

					if (bestAlpha > 0.05) {
						const dotR = DOT_RADIUS * bestScale;
						const ringR = dotR + RING_THICKNESS * bestAlpha;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR + (ringR - dotR) / 2, 0, Math.PI * 2);
						ctx!.strokeStyle = RING_COLOR;
						ctx!.globalAlpha = bestAlpha;
						ctx!.lineWidth = ringR - dotR;
						ctx!.stroke();
						ctx!.globalAlpha = 1;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					} else {
						ctx!.beginPath();
						ctx!.arc(x, y, DOT_RADIUS, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					}
				}
			}

			lastDrawTime = time;
			animId = requestAnimationFrame(draw);
		}

		let lastDrawTime = 0;
		const ro = new ResizeObserver(() => {
			resize();
			draw(lastDrawTime);
		});
		ro.observe(canvas);

		resize();

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReducedMotion) {
			draw(0);
			cancelAnimationFrame(animId!);
		} else {
			let isVisible = false;
			const io = new IntersectionObserver(([entry]) => {
				isVisible = entry.isIntersecting;
				if (isVisible) {
					animId = requestAnimationFrame(draw);
				} else {
					cancelAnimationFrame(animId);
				}
			}, { threshold: 0 });
			io.observe(canvas.closest('.dine-drink')!);
		}
	}

	document.addEventListener('astro:page-load', initDineDrinkDots);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initDineDrinkDots);
	} else {
		initDineDrinkDots();
	}
</script>
