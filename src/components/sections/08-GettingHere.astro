---
const parkingUrl = 'https://grs-reservationserviceesb.lazparking.com/checkout/index-event.html?l=207421,207422,207424,207423&wk=a6995ca660704d8793b49f02f54379c8';
---

<section class="getting-here">
	<canvas id="getting-here-dots" class="getting-here__canvas"></canvas>
	<div class="getting-here__inner">
		<h2 class="getting-here__heading">Getting Here <br>is Easy</h2>

		<div class="getting-here__cards getting-here__cards--top">
			<div class="getting-here__card getting-here__card--purple getting-here__card--reserve">
				<a href={parkingUrl} target="_blank" rel="noopener noreferrer" class="getting-here__card--link getting-here__reserve-link">
					<div class="getting-here__icon">
						<img src="/images/08-getting-here/parking.svg" alt="" width="50" height="63" />
					</div>
					<p class="getting-here__label">Reserve your convenient public parking today</p>
					<span class="getting-here__card-cue">Reserve Parking <span aria-hidden="true">&rarr;</span><span class="sr-only"> (opens in new window)</span></span>
				</a>
				<div class="getting-here__card-body" id="getting-here-body-reserve">
					<div class="getting-here__card-body-inner">
						<p class="getting-here__note">A limited number of free parking options will also be available in the area.</p>
					</div>
				</div>
				<button class="getting-here__expand" type="button" aria-expanded="false" aria-controls="getting-here-body-reserve">
					<span class="getting-here__expand-label">Read more</span>
					<svg class="getting-here__expand-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</button>
			</div>

			<div class="getting-here__card getting-here__card--blue">
				<div class="getting-here__icon">
					<img src="/images/08-getting-here/car.svg" alt="" width="68" height="51" />
				</div>
				<p class="getting-here__label">Easy rideshare drop-off</p>
				<div class="getting-here__card-body" id="getting-here-body-rideshare">
					<div class="getting-here__card-body-inner">
						<p class="getting-here__note">The designated rideshare pick-up and drop-off lot is located at 135 E. Angeleno Ave. directly across from Hotel Burbank.</p>
					</div>
				</div>
				<button class="getting-here__expand" type="button" aria-expanded="false" aria-controls="getting-here-body-rideshare">
					<span class="getting-here__expand-label">Read more</span>
					<svg class="getting-here__expand-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</button>
			</div>
		</div>

		<div class="getting-here__cards getting-here__cards--bottom">
			<div class="getting-here__card getting-here__card--coral getting-here__card--detailed">
				<div class="getting-here__icon">
					<img src="/images/08-getting-here/metro.svg" alt="" width="47" height="64" />
				</div>
				<h3 class="getting-here__card-heading">Metrolink Rail Service</h3>
				<div class="getting-here__card-body" id="getting-here-body-metrolink">
					<div class="getting-here__card-body-inner">
						<p class="getting-here__card-text">The Downtown Burbank Station connects to convenient regional rail service throughout Southern California via the Antelope Valley and Ventura County Lines.</p>
						<p class="getting-here__card-text">Direct connections include:</p>
						<ul class="getting-here__card-list">
							<li>Union Station (with transfers to Amtrak and Metro Rail)</li>
							<li>Glendale</li>
							<li>Santa Clarita</li>
							<li>Ventura County</li>
						</ul>
						<p class="getting-here__card-text">The Fan Zone is a short walk or free bus transfer from the Burbank – Downtown Metrolink station. Schedules are available <a href="https://metrolinktrains.com/schedules/" target="_blank" rel="noopener noreferrer">here</a>. Use the SoCal Day Pass for all-day access!</p>
					</div>
				</div>
				<button class="getting-here__expand" type="button" aria-expanded="false" aria-controls="getting-here-body-metrolink">
					<span class="getting-here__expand-label">Read more</span>
					<svg class="getting-here__expand-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</button>
			</div>

			<div class="getting-here__card getting-here__card--pink getting-here__card--detailed">
				<div class="getting-here__icon">
					<img src="/images/08-getting-here/parking.svg" alt="" width="50" height="63" />
				</div>
				<h3 class="getting-here__card-heading">Park and Ride</h3>
				<div class="getting-here__card-body" id="getting-here-body-parkride">
					<div class="getting-here__card-body-inner">
						<p class="getting-here__card-text"><strong>Option 1:</strong> Park at Universal City/Studio City station and take BurbankBus FREE directly to the Fan Zone, with service every 15 minutes.</p>
						<p class="getting-here__card-text"><strong>Option 2:</strong> Park at North Hollywood station and take Metro line 94 directly to the Fan Zone, with service every 20 minutes.</p>
					</div>
				</div>
				<button class="getting-here__expand" type="button" aria-expanded="false" aria-controls="getting-here-body-parkride">
					<span class="getting-here__expand-label">Read more</span>
					<svg class="getting-here__expand-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</button>
			</div>

			<div class="getting-here__card getting-here__card--cyan getting-here__card--detailed">
				<div class="getting-here__icon">
					<img src="/images/08-getting-here/bus.svg" alt="" width="63" height="65" />
				</div>
				<h3 class="getting-here__card-heading">Bus Service</h3>
				<div class="getting-here__card-body" id="getting-here-body-bus">
					<div class="getting-here__card-body-inner">
						<p class="getting-here__card-text"><strong>BurbankBus (Special Weekend FREE Shuttle Service):</strong> Transfer from Metro B line at Universal City/Studio City station, or board at any BurbankBus Pink Route stop and take BurbankBus FREE directly to the Fan Zone, with service every 15 minutes.</p>
						<p class="getting-here__card-text"><strong>Metro Bus:</strong> Take lines 92, 94, 154, 155, 164, 165, 294, or 296 to any stop on First St. between Magnolia Blvd. and Angeleno Ave. to access the event.</p>
						<p class="getting-here__card-text">Plan your route at <a href="https://www.metro.net" target="_blank" rel="noopener noreferrer">metro.net</a> or call <a href="tel:+13234636782">(323) GO-METRO</a>.</p>
					</div>
				</div>
				<button class="getting-here__expand" type="button" aria-expanded="false" aria-controls="getting-here-body-bus">
					<span class="getting-here__expand-label">Read more</span>
					<svg class="getting-here__expand-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><path d="M3 5l4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
				</button>
			</div>
		</div>

		<a href="/info/" class="getting-here__btn">Know Before You Go</a>
	</div>
</section>

<section class="fanzone-map">
	<div class="fanzone-map__inner">
		<img src="/images/dtb-map.webp" alt="Downtown Burbank Fan Zone parking and event map. Parking lots surround the event: VIP Prepaid Parking Only lots near Magnolia Blvd. and Third St. and near Angeleno Ave.; a Same Day &amp; PrePaid Parking lot and a LAZ Parking Operator lot in the center near San Fernando Blvd.; a Same Day &amp; PrePaid Parking lot near Third St. and Angeleno Ave.; and Same Day Parking lots near Orange Grove Ave. The Street Fair runs along San Fernando Blvd., with the VIP Terrace Watch Party at the west end by Magnolia Blvd., Activations and Kick Off Cuisine nearby, Passport Lounge Watch Parties along San Fernando Blvd. and near Orange Grove Ave., Watch Party Areas with Stages running north-south near the center and near Angeleno Ave., and a shuttle stop near Palm Ave. and N First St." width="1440" />
	</div>
</section>

<style>
	.getting-here {
		background-color: #EDAE47;
		color: white;
		padding: 4rem 2rem 5rem;
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	.getting-here__canvas {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 55%;
		pointer-events: none;
	}

	.getting-here__inner {
		max-width: 1250px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.getting-here__heading {
		font-family: var(--font-family);
		font-size: clamp(1.8rem, 3.5vw, 40px);
		font-weight: 700;
		text-transform: uppercase;
		margin: 0 0 2.5rem;
		letter-spacing: 0.02em;
	}
	.getting-here__heading br {
		display: none;
	}

	.getting-here__cards {
		display: flex;
		gap: 1.25rem;
		margin-bottom: 1.25rem;
	}

	.getting-here__cards--bottom {
		margin-bottom: 2.5rem;
		align-items: flex-start;
	}

	.getting-here__card {
		flex: 1;
		border-radius: 12px;
		padding: 2.5rem 2rem 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 200px;
	}

	.getting-here__card--detailed {
		justify-content: flex-start;
		align-items: stretch;
		text-align: left;
		padding: 2rem 1.75rem;
	}

	.getting-here__card--detailed .getting-here__icon {
		align-self: center;
	}

	.getting-here__card--purple {
		background-color: #9B59B6;
	}

	.getting-here__card--link {
		text-decoration: none;
		color: inherit;
		cursor: pointer;
		transition: transform 0.2s, filter 0.2s;
	}

	.getting-here__card--link:hover,
	.getting-here__card--link:focus-visible {
		transform: translateY(-3px);
		filter: brightness(1.06);
		outline: none;
	}

	.getting-here__card--link:focus-visible {
		box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.7);
	}

	.getting-here__card-cue {
		margin-top: 0.9rem;
		font-family: var(--font-family);
		font-size: clamp(12px, 1.2vw, 0.9rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border-bottom: 2px solid currentColor;
		padding-bottom: 2px;
	}

	.getting-here__card--coral {
		background-color: var(--color-coral);
	}

	.getting-here__card--pink {
		background-color: #EE2A7B;
	}

	.getting-here__card--blue {
		background-color: #7BA3CC;
	}

	.getting-here__card--cyan {
		background-color: var(--color-coral);
	}

	.getting-here__icon {
		margin-bottom: 1.25rem;
	}

	.getting-here__icon img {
		width: auto;
		height: 60px;
	}

	.getting-here__label {
		font-family: var(--font-family);
		font-size: clamp(13px, 1.5vw, 1.1rem);
		font-weight: 700;
		line-height: 1.4;
		margin: 0;
	}

	.getting-here__reserve-link {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: 100%;
		margin-bottom: 1.5rem;
	}


	.getting-here__note {
		font-family: var(--font-family);
		font-size: clamp(12px, 1.1vw, 0.85rem);
		font-weight: 400;
		line-height: 1.4;
		margin: auto;
		max-width: 40ch;
		opacity: 0.9;
	}

	.getting-here__card-heading {
		font-family: var(--font-family);
		font-size: clamp(1.1rem, 1.8vw, 1.4rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		margin: 0 0 0.75rem;
		text-align: center;
	}

	.getting-here__card-text {
		font-family: var(--font-family);
		font-size: clamp(13px, 1vw, 0.95rem);
		font-weight: 400;
		line-height: 1.5;
		margin: 0 0 0.75rem;
	}

	.getting-here__card-text:last-child {
		margin-bottom: 0;
	}

	.getting-here__card-text a {
		color: inherit;
		text-decoration: underline;
		font-weight: 700;
	}

	.getting-here__card-list {
		font-family: var(--font-family);
		font-size: clamp(13px, 1vw, 0.95rem);
		font-weight: 400;
		line-height: 1.5;
		margin: 0 0 0.75rem;
		padding-left: 1.25rem;
	}

	.getting-here__card-list li {
		margin-bottom: 0.25rem;
	}

	.getting-here__card-body {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.35s ease;
		width: 100%;
	}

	.getting-here__card--expanded .getting-here__card-body {
		grid-template-rows: 1fr;
	}

	.getting-here__card-body-inner {
		overflow: hidden;
		min-height: 0;
	}

	.getting-here__card--expanded .getting-here__card-body-inner {
		padding-bottom: 1rem;
	}

	.getting-here__expand {
		appearance: none;
		background: rgba(255, 255, 255, 0.18);
		color: inherit;
		border: 0;
		border-radius: 999px;
		padding: 0.5rem 1rem;
		font-family: var(--font-family);
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin-top: auto;
		align-self: center;
		transition: background-color 0.2s ease;
	}

	.getting-here__expand:hover,
	.getting-here__expand:focus-visible {
		background: rgba(255, 255, 255, 0.32);
	}

	.getting-here__expand:focus-visible {
		outline: 2px solid white;
		outline-offset: 2px;
	}

	.getting-here__expand-icon {
		transition: transform 0.25s ease;
	}

	.getting-here__card--expanded .getting-here__expand-icon {
		transform: rotate(180deg);
	}

	@media (prefers-reduced-motion: reduce) {
		.getting-here__card-body,
		.getting-here__expand-icon {
			transition: none;
		}
	}

	.getting-here__btn {
		display: inline-block;
		background-color: var(--color-coral);
		color: white;
		font-family: var(--font-family);
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.75rem 2rem;
		border-radius: 4px;
		text-decoration: none;
		transition: filter 0.3s;
	}

	.getting-here__btn:hover {
		filter: brightness(1.1);
	}

	.fanzone-map {
		background-color: #f5f5f5;
		padding: 4rem 2rem;
		text-align: center;
	}

	.fanzone-map__inner {
		max-width: 1250px;
		margin: 0 auto;
	}

	.fanzone-map__inner img {
		width: 100%;
		height: auto;
	}

	@media (max-width: 900px) {
		.getting-here__cards--bottom {
			flex-direction: column;
		}

		.getting-here__card--detailed {
			min-height: unset;
		}
	}

	@media (max-width: 768px) {
		.getting-here__cards--top {
			display: grid;
			grid-template-columns: 1fr 1fr;
		}

		.getting-here__card {
			min-height: unset;
			padding: 2.5rem 1rem 1rem;
		}
		.getting-here__card--detailed {
			padding: 1.75rem 1.25rem;
		}
		.getting-here__label {
			font-size: 15px;
		}
		.getting-here__icon img {
			height: 30px;
		}
		.getting-here__card--detailed .getting-here__icon img {
			height: 40px;
		}
		.getting-here__card-heading {
			font-size: 1.1rem;
		}
		.getting-here__card-text,
		.getting-here__card-list {
			font-size: 14px;
		}
		.getting-here__heading  br{
			display: inline;
		}
		.getting-here__btn {
			font-size: 13px;
			padding: 0.75rem 1.75rem;
		}
	}
</style>

<script>
	function initGettingHereDots() {
		const canvas = document.getElementById('getting-here-dots') as HTMLCanvasElement;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const BG = '#D99A3E';
		const DOT_COLOR = '#C98E38';
		const RING_COLOR = '#F2CB6E';
		const DOT_RADIUS = 10;
		const RING_THICKNESS = 6;
		const SPACING = 60;

		let cols = 0;
		let rows = 0;
		let animId: number;

		function resize() {
			const dpr = window.devicePixelRatio || 1;
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;
			canvas.width = w * dpr;
			canvas.height = h * dpr;
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
			cols = Math.ceil(w / SPACING) + 1;
			rows = Math.ceil(h / SPACING) + 1;
		}

		// Pulse system
		interface Pulse {
			cx: number;
			cy: number;
			birth: number;
			duration: number;
			reach: number;
		}

		const pulses: Pulse[] = [];
		const PULSE_INTERVAL = 6000;
		const PULSE_DURATION = 8000;
		const PULSE_REACH = 300;
		let lastPulseTime = -PULSE_INTERVAL;

		function spawnPulse(time: number) {
			pulses.push({
				cx: 0.1 + Math.random() * 0.8,
				cy: 0.1 + Math.random() * 0.8,
				birth: time,
				duration: PULSE_DURATION + Math.random() * 1500,
				reach: PULSE_REACH + Math.random() * 100,
			});
			while (pulses.length > 4) {
				pulses.shift();
			}
		}

		function draw(time: number) {
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;

			ctx!.fillStyle = BG;
			ctx!.fillRect(0, 0, w, h);

			if (time - lastPulseTime > PULSE_INTERVAL) {
				spawnPulse(time);
				lastPulseTime = time;
			}

			const offsetX = ((w % SPACING) / 2);
			const offsetY = ((h % SPACING) / 2);

			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					const x = offsetX + c * SPACING;
					const y = offsetY + r * SPACING;

					let bestAlpha = 0;
					let bestScale = 1;

					for (const p of pulses) {
						const age = time - p.birth;
						if (age < 0 || age > p.duration) continue;

						const pcx = p.cx * w;
						const pcy = p.cy * h;
						const dist = Math.sqrt((x - pcx) ** 2 + (y - pcy) ** 2);

						if (dist > p.reach) continue;

						const proximity = 1 - dist / p.reach;
						const progress = age / p.duration;
						const breathe = Math.sin(progress * Math.PI);

						const alpha = proximity * breathe;
						if (alpha > bestAlpha) {
							bestAlpha = alpha;
							bestScale = 1 + 0.4 * alpha;
						}
					}

					if (bestAlpha > 0.05) {
						const dotR = DOT_RADIUS * bestScale;
						const ringR = dotR + RING_THICKNESS * bestAlpha;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR + (ringR - dotR) / 2, 0, Math.PI * 2);
						ctx!.strokeStyle = RING_COLOR;
						ctx!.globalAlpha = bestAlpha;
						ctx!.lineWidth = ringR - dotR;
						ctx!.stroke();
						ctx!.globalAlpha = 1;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					} else {
						ctx!.beginPath();
						ctx!.arc(x, y, DOT_RADIUS, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					}
				}
			}

			lastDrawTime = time;
			animId = requestAnimationFrame(draw);
		}

		let lastDrawTime = 0;
		const ro = new ResizeObserver(() => {
			resize();
			draw(lastDrawTime);
		});
		ro.observe(canvas);

		resize();

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReducedMotion) {
			draw(0);
			cancelAnimationFrame(animId!);
		} else {
			let isVisible = false;
			const io = new IntersectionObserver(([entry]) => {
				isVisible = entry.isIntersecting;
				if (isVisible) {
					animId = requestAnimationFrame(draw);
				} else {
					cancelAnimationFrame(animId);
				}
			}, { threshold: 0 });
			io.observe(canvas.closest('.getting-here')!);
		}
	}

	document.addEventListener('astro:page-load', initGettingHereDots);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initGettingHereDots);
	} else {
		initGettingHereDots();
	}

	function initGettingHereExpanders() {
		const buttons = document.querySelectorAll<HTMLButtonElement>('.getting-here__expand');
		buttons.forEach((btn) => {
			if (btn.dataset.bound === 'true') return;
			btn.dataset.bound = 'true';
			btn.addEventListener('click', () => {
				const card = btn.closest('.getting-here__card');
				if (!card) return;
				const expanded = card.classList.toggle('getting-here__card--expanded');
				btn.setAttribute('aria-expanded', String(expanded));
				const label = btn.querySelector('.getting-here__expand-label');
				if (label) label.textContent = expanded ? 'Read less' : 'Read more';
			});
		});
	}

	document.addEventListener('astro:page-load', initGettingHereExpanders);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initGettingHereExpanders);
	} else {
		initGettingHereExpanders();
	}
</script>
