<section class="getting-here">
	<canvas id="getting-here-dots" class="getting-here__canvas"></canvas>
	<div class="getting-here__inner">
		<h2 class="getting-here__heading">Getting Here <br>is Easy</h2>

		<div class="getting-here__cards">
			<div class="getting-here__card getting-here__card--purple">
				<div class="getting-here__icon">
					<img src="/images/08-getting-here/parking.svg" alt="" width="50" height="63" />
				</div>
				<p class="getting-here__label">Convenient public parking garages with FREE options</p>
			</div>

			<div class="getting-here__card getting-here__card--coral">
				<div class="getting-here__icon">
					<img src="/images/08-getting-here/metro.svg" alt="" width="47" height="64" />
				</div>
				<p class="getting-here__label">Metrolink &amp;<br> Amtrak access</p>
			</div>

			<div class="getting-here__card getting-here__card--pink">
				<div class="getting-here__icon">
					<img src="/images/08-getting-here/bus.svg" alt="" width="63" height="65" />
				</div>
				<p class="getting-here__label">Public transportation routes</p>
			</div>

			<div class="getting-here__card getting-here__card--blue">
				<div class="getting-here__icon">
					<img src="/images/08-getting-here/car.svg" alt="" width="68" height="51" />
				</div>
				<p class="getting-here__label">Easy rideshare drop-off</p>
			</div>
		</div>

		<a href="https://dtnbur.com/parking/" target="_blank" rel="noopener noreferrer" class="getting-here__btn">Parking & Directions<span class="sr-only"> (opens in new window)</span></a>
	</div>
</section>

<section class="fanzone-map">
	<div class="fanzone-map__inner">
		<img src="/images/dtb-map.webp" alt="Downtown Burbank FanZone map showing Watch Party Areas, International Street Fair, Passport Lounges, Kick Off Cuisine, VIP Terrace, Activations, and Stages" width="1440" />
	</div>
</section>

<style>
	.getting-here {
		background-color: #EDAE47;
		color: white;
		padding: 4rem 2rem 5rem;
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	.getting-here__canvas {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 55%;
		pointer-events: none;
	}

	.getting-here__inner {
		max-width: 1250px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.getting-here__heading {
		font-family: var(--font-family);
		font-size: clamp(1.8rem, 3.5vw, 40px);
		font-weight: 700;
		text-transform: uppercase;
		margin: 0 0 2.5rem;
		letter-spacing: 0.02em;
	}
	.getting-here__heading br {
		display: none;
	}

	.getting-here__cards {
		display: flex;
		gap: 1.25rem;
		margin-bottom: 2.5rem;
	}

	.getting-here__card {
		flex: 1;
		border-radius: 12px;
		padding: 2.5rem 2rem 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 200px;
	}

	.getting-here__card--purple {
		background-color: #9B59B6;
	}

	.getting-here__card--coral {
		background-color: var(--color-coral);
	}

	.getting-here__card--pink {
		background-color: #EE2A7B;
	}

	.getting-here__card--blue {
		background-color: #7BA3CC;
	}

	.getting-here__icon {
		margin-bottom: 1.25rem;
	}

	.getting-here__icon img {
		width: auto;
		height: 60px;
	}

	.getting-here__label {
		font-family: var(--font-family);
		font-size: clamp(13px, 1.5vw, 1.1rem);
		font-weight: 700;
		line-height: 1.4;
		margin: 0;
	}

	.getting-here__btn {
		display: inline-block;
		background-color: var(--color-coral);
		color: white;
		font-family: var(--font-family);
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.75rem 2rem;
		border-radius: 4px;
		text-decoration: none;
		transition: filter 0.3s;
	}

	.getting-here__btn:hover {
		filter: brightness(1.1);
	}

	.fanzone-map {
		background-color: #f5f5f5;
		padding: 4rem 2rem;
		text-align: center;
	}

	.fanzone-map__inner {
		max-width: 1250px;
		margin: 0 auto;
	}

	.fanzone-map__inner img {
		width: 100%;
		height: auto;
	}

	@media (max-width: 768px) {
		.getting-here__cards {
					display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: 1fr 1fr;
		}

		.getting-here__card {
			min-height: unset;
			padding: 2.5rem 1rem 1rem;
		}
		.getting-here__label {
			font-size: 15px;
		}
		.getting-here__icon img {
			height: 30px;
		}
		.getting-here__heading  br{
			display: inline;
		}
		.getting-here__btn {
			font-size: 13px;
			padding: 0.75rem 1.75rem;
		}
	}
</style>

<script>
	function initGettingHereDots() {
		const canvas = document.getElementById('getting-here-dots') as HTMLCanvasElement;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const BG = '#D99A3E';
		const DOT_COLOR = '#C98E38';
		const RING_COLOR = '#F2CB6E';
		const DOT_RADIUS = 10;
		const RING_THICKNESS = 6;
		const SPACING = 60;

		let cols = 0;
		let rows = 0;
		let animId: number;

		function resize() {
			const dpr = window.devicePixelRatio || 1;
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;
			canvas.width = w * dpr;
			canvas.height = h * dpr;
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
			cols = Math.ceil(w / SPACING) + 1;
			rows = Math.ceil(h / SPACING) + 1;
		}

		// Pulse system
		interface Pulse {
			cx: number;
			cy: number;
			birth: number;
			duration: number;
			reach: number;
		}

		const pulses: Pulse[] = [];
		const PULSE_INTERVAL = 6000;
		const PULSE_DURATION = 8000;
		const PULSE_REACH = 300;
		let lastPulseTime = -PULSE_INTERVAL;

		function spawnPulse(time: number) {
			pulses.push({
				cx: 0.1 + Math.random() * 0.8,
				cy: 0.1 + Math.random() * 0.8,
				birth: time,
				duration: PULSE_DURATION + Math.random() * 1500,
				reach: PULSE_REACH + Math.random() * 100,
			});
			while (pulses.length > 4) {
				pulses.shift();
			}
		}

		function draw(time: number) {
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;

			ctx!.fillStyle = BG;
			ctx!.fillRect(0, 0, w, h);

			if (time - lastPulseTime > PULSE_INTERVAL) {
				spawnPulse(time);
				lastPulseTime = time;
			}

			const offsetX = ((w % SPACING) / 2);
			const offsetY = ((h % SPACING) / 2);

			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					const x = offsetX + c * SPACING;
					const y = offsetY + r * SPACING;

					let bestAlpha = 0;
					let bestScale = 1;

					for (const p of pulses) {
						const age = time - p.birth;
						if (age < 0 || age > p.duration) continue;

						const pcx = p.cx * w;
						const pcy = p.cy * h;
						const dist = Math.sqrt((x - pcx) ** 2 + (y - pcy) ** 2);

						if (dist > p.reach) continue;

						const proximity = 1 - dist / p.reach;
						const progress = age / p.duration;
						const breathe = Math.sin(progress * Math.PI);

						const alpha = proximity * breathe;
						if (alpha > bestAlpha) {
							bestAlpha = alpha;
							bestScale = 1 + 0.4 * alpha;
						}
					}

					if (bestAlpha > 0.05) {
						const dotR = DOT_RADIUS * bestScale;
						const ringR = dotR + RING_THICKNESS * bestAlpha;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR + (ringR - dotR) / 2, 0, Math.PI * 2);
						ctx!.strokeStyle = RING_COLOR;
						ctx!.globalAlpha = bestAlpha;
						ctx!.lineWidth = ringR - dotR;
						ctx!.stroke();
						ctx!.globalAlpha = 1;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					} else {
						ctx!.beginPath();
						ctx!.arc(x, y, DOT_RADIUS, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					}
				}
			}

			lastDrawTime = time;
			animId = requestAnimationFrame(draw);
		}

		let lastDrawTime = 0;
		const ro = new ResizeObserver(() => {
			resize();
			draw(lastDrawTime);
		});
		ro.observe(canvas);

		resize();

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReducedMotion) {
			draw(0);
			cancelAnimationFrame(animId!);
		} else {
			let isVisible = false;
			const io = new IntersectionObserver(([entry]) => {
				isVisible = entry.isIntersecting;
				if (isVisible) {
					animId = requestAnimationFrame(draw);
				} else {
					cancelAnimationFrame(animId);
				}
			}, { threshold: 0 });
			io.observe(canvas.closest('.getting-here')!);
		}
	}

	document.addEventListener('astro:page-load', initGettingHereDots);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initGettingHereDots);
	} else {
		initGettingHereDots();
	}
</script>
