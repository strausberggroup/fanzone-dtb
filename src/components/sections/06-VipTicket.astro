					</li>
				</ul>
			</div>

			<a
				href="https://tickets.cbfproductions.com/e/los-angeles-world-cup-26-fan-zone-downtown-burbank?utm_source=fanzone-dtb&utm_medium=vip-cta&utm_campaign=worldcup26"
				target="_blank"
				rel="noopener noreferrer"
				class="vip__button"
			>
				Get Tickets
			</a>
		</div>
	</div>
</section>

<style>
	.vip {
		background-color: var(--color-cream);
		padding: 5rem 2rem;
	}

	.vip__inner {
		max-width: 1150px;
		margin: 0 auto;
		display: flex;
		align-items: start;
		/* justify-content: space-between; */
		gap: clamp(2rem, 5vw, 4rem);
	}

	.vip__image {
		flex-shrink: 0;
		width: 100%;
		max-width: 450px;
	}

	.vip__image img {
		width: 100%;
		height: auto;
		border-radius: 16px;

	}

	.vip__heading {
		font-size: clamp(1.75rem, 4vw, 40px);
		font-weight: 700;
		text-transform: uppercase;
		color: var(--color-blue);
		line-height: normal;
		margin-bottom: 1rem;
	}

	.vip__intro {
		font-size: 16px;
		line-height: 1.6;
		color: var(--color-dark);
		margin-bottom: 1.75rem;
	}

	.vip__experience {
		margin-bottom: 1.75rem;
	}

	.vip__experience-heading {
		font-size: clamp(1.125rem, 2.25vw, 22px);
		font-weight: 700;
		color: var(--color-blue);
		line-height: 1.25;
		margin-bottom: 0.5rem;
	}

	.vip__experience-description {
		font-size: 16px;
		line-height: 1.6;
		color: var(--color-dark);
		margin-bottom: 0.75rem;
	}

	.vip__list {
		list-style: none;
		padding: 0;
	}

	.vip__list li {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 18px;
		font-weight: 700;
		color: var(--color-dark);
		padding: 0.6em 0;
	}

	.vip__list li:last-child {
		border-bottom: none;
	}

	.vip__check {
		flex-shrink: 0;
		width: 28px;
		height: auto;
	}

	.vip__button {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.875rem 2rem;
		background-color: var(--color-coral);
		color: #fff;
		border-radius: 8px;
		font-family: var(--font-family);
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		transition: filter 0.3s;
	}

	.vip__button:hover {
		filter: brightness(1.1);
	}

	@media (max-width: 768px) {
		.vip {
			padding: 3rem 2rem 1rem;
		}
		.vip__inner {
			flex-direction: column;
		}

		.vip__image {
			width: 100%;
			max-width: unset;
		}
		.vip__image img {
			aspect-ratio: 3/2;
			object-fit: cover;
		}
		.vip__intro,
		.vip__experience-description {
			font-size: 14px;
		}
		.vip__list li {
			font-size: 15px;
		}
		.vip__check {
			width: 20px;
		}
		.vip__button {
			font-size: 13px;
		}
	}


		@media (max-width: 480px) {
			.vip__heading {
				max-width: 310px;
				line-height: 1.1;
			}
		}
</style>
