---
import photo from '../../assets/images/06-vip-ticket/bottles-of-wine.jpg';
import chefPhoto from '../../assets/images/10-dine-drink/chef-zakarian.jpg';
import loudLuxuryPhoto from '../../assets/images/06-vip-ticket/loud-luxury.jpg';
import bebeRexhaPhoto from '../../assets/images/06-vip-ticket/bebe-rexha.jpg';

const check = `<svg class="vip__check" aria-hidden="true" width="16" height="15" viewBox="0 0 36 33" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M35.7713 0.7257C35.4102 0.1264 34.7143-0.1342 34.0446 0.0677 27.2035 2.1655 19.0559 12.8433 11.2432 23.8078 7.9277 18.2637 4.4152 16.4135 0.7846 18.3092 0.3316 18.5504 0.0427 18.9868 0.0034 19.495-0.0295 20.0097 0.1937 20.4918 0.6139 20.7979 3.2466 22.7067 5.9778 26.088 9.2276 31.4431 9.8185 32.4203 10.8493 33.0002 11.9982 33.0002H12.0507C13.2325 32.9806 14.283 32.3617 14.8607 31.3389 18.3797 25.0847 21.8331 19.6056 25.2602 14.8368 28.6938 10.068 32.1078 6.0093 35.5481 2.589 36.0536 2.0874 36.1455 1.3381 35.7713 0.7257Z" fill="currentColor"/></svg>`;
---

<section class="vip">
	<div class="vip__inner">
		<header class="vip__header">
			<p class="vip__eyebrow">Ticketed Experiences</p>
			<h2 class="vip__heading">Elevate Your Match Day Experience</h2>
			<p class="vip__intro">Take your watch party to the next level with exclusive ticketed experiences designed for comfort, energy, and unforgettable views of the match.</p>
		</header>

		<div class="vip__experiences">
			<article class="vip__card vip__card--blue">
				<div class="vip__card-media">
					<img src={chefPhoto.src} alt="Celebrity Chef Geoffrey Zakarian" width="500" height="375" class="vip__card-image vip__card-image--chef" loading="lazy" />
				</div>
				<div class="vip__card-body">
					<span class="vip__notch vip__notch--left" aria-hidden="true"></span>
					<span class="vip__notch vip__notch--right" aria-hidden="true"></span>
					<h3 class="vip__card-title">Culinary Experience with Celebrity Chef Geoffrey Zakarian</h3>
					<p class="vip__card-desc">Watch the match from an exclusive private terrace while enjoying a curated culinary experience by Celebrity Chef Geoffrey Zakarian.</p>
					<ul class="vip__perks">
						<li><Fragment set:html={check} />Unlimited food and drink pairings from 12 PM – 3 PM (The terrace will remain open with a bar after 3 PM)</li>
						<li><Fragment set:html={check} />Access to a private terrace overlooking downtown Burbank</li>
						<li><Fragment set:html={check} />Large LED screens with full sound for match viewing</li>
						<li><Fragment set:html={check} />Lounge seating, cocktail tables, and shaded areas</li>
						<li><Fragment set:html={check} />Live cooking demonstrations by Chef Zakarian (pre-match)</li>
						<li><Fragment set:html={check} />Exclusive, limited-capacity experience with a relaxed, upscale ambiance</li>
					</ul>
				</div>
			</article>

			<article class="vip__card vip__card--coral">
				<div class="vip__card-media">
					<img src={photo.src} alt="Bottles of wine on ice at a VIP event" width="500" height="375" class="vip__card-image" loading="lazy" />
				</div>
				<div class="vip__card-body">
					<span class="vip__notch vip__notch--left" aria-hidden="true"></span>
					<span class="vip__notch vip__notch--right" aria-hidden="true"></span>
					<h3 class="vip__card-title">Passport Lounge Watch Parties</h3>
					<p class="vip__card-desc">Explore three unique themed lounges across Downtown Burbank, each offering its own vibe for watching the match.</p>
					<ul class="vip__perks">
						<li><Fragment set:html={check} />Access to three distinct themed lounges throughout downtown</li>
						<li><Fragment set:html={check} />Freedom to move between lounges during the event</li>
						<li><Fragment set:html={check} />Shaded lounge areas with comfortable seating</li>
						<li><Fragment set:html={check} />Stylish lounge furniture and social spaces</li>
						<li><Fragment set:html={check} />Large LED screens with full game sound in each location</li>
						<li><Fragment set:html={check} />Immersive, multi-atmosphere World Cup viewing experience</li>
					</ul>
				</div>
			</article>

			<article class="vip__card vip__card--pink">
				<div class="vip__card-media">
					<div class="vip__flip" data-flip>
						<div class="vip__flip-inner">
							<div class="vip__flip-face vip__flip-face--front">
								<img src={loudLuxuryPhoto.src} alt="Loud Luxury performing live" width="500" height="375" class="vip__card-image vip__card-image--loud-luxury" loading="lazy" />
								<span class="vip__flip-tag">July 18 · Loud Luxury</span>
							</div>
							<div class="vip__flip-face vip__flip-face--back">
								<img src={bebeRexhaPhoto.src} alt="Bebe Rexha press shot" width="500" height="375" class="vip__card-image vip__card-image--bebe" loading="lazy" />
								<span class="vip__flip-tag">July 19 · Bebe Rexha</span>
							</div>
						</div>
					</div>
				</div>
				<div class="vip__card-body">
					<span class="vip__notch vip__notch--left" aria-hidden="true"></span>
					<span class="vip__notch vip__notch--right" aria-hidden="true"></span>
					<h3 class="vip__card-title">Concert Experiences Featuring <button type="button" class="vip__flip-name" data-flip-to="front">Loud Luxury</button> &amp; <button type="button" class="vip__flip-name" data-flip-to="back">Bebe Rexha</button></h3>
					<p class="vip__card-desc">After the watch parties, experience a high-energy live concert celebration — two nights, two headliners: Loud Luxury on July 18th and Bebe Rexha on July 19th.</p>
					<ul class="vip__perks">
						<li><Fragment set:html={check} />Entry to a designated Watch Party area, located at 211 E. Olive Ave. in Downtown Burbank</li>
						<li><Fragment set:html={check} />Admission to post-match live concerts featuring Loud Luxury (July 18) and Bebe Rexha (July 19)</li>
						<li><Fragment set:html={check} />Massive LED screen with full sound for live match viewing</li>
						<li><Fragment set:html={check} />Access to communal seating areas</li>
						<li><Fragment set:html={check} />On-site food and beverage vendors (available for purchase)</li>
						<li><Fragment set:html={check} />High-energy, large-scale fan atmosphere</li>
					</ul>
				</div>
			</article>
		</div>

		<a
			href="https://tickets.cbfproductions.com/e/los-angeles-world-cup-26-fan-zone-downtown-burbank/tickets?utm_source=fanzone-dtb&utm_medium=vip-cta&utm_campaign=worldcup26"
			target="_blank"
			rel="noopener noreferrer"
			class="vip__button"
		>
			Get Tickets
		</a>
	</div>
</section>

<style>
	.vip {
		background-color: var(--color-cream);
		padding: 5rem 2rem;
	}

	.vip__inner {
		max-width: 1180px;
		margin: 0 auto;
	}

	.vip__header {
		text-align: center;
		max-width: 720px;
		margin: 0 auto 3rem;
	}

	.vip__eyebrow {
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--color-coral);
		margin: 0 0 0.65rem;
	}

	.vip__heading {
		font-size: clamp(1.75rem, 4vw, 44px);
		font-weight: 700;
		text-transform: uppercase;
		color: var(--color-blue);
		line-height: 1.1;
		margin: 0 0 1rem;
		text-wrap: balance;
	}

	.vip__intro {
		font-size: clamp(1rem, 1.3vw, 17px);
		line-height: 1.65;
		color: var(--color-dark);
		margin: 0;
		text-wrap: pretty;
	}

	.vip__experiences {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.75rem;
		margin-bottom: 3rem;
	}

	.vip__card {
		display: flex;
		flex-direction: column;
		border-radius: 18px;
		overflow: hidden;
		color: #fff;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.vip__card:hover {
		transform: translateY(-4px);
		box-shadow: 0 18px 38px rgba(0, 0, 0, 0.16);
	}

	.vip__card--blue { background-color: var(--color-blue); }
	.vip__card--coral { background-color: var(--color-coral); }
	.vip__card--pink { background-color: var(--color-pink); }

	.vip__card-media {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background-color: rgba(0, 0, 0, 0.1);
	}

	.vip__card-image {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.vip__card-image--chef {
		object-position: center 30%;
	}

	.vip__card-image--loud-luxury {
		object-position: center 15%;
	}

	.vip__card-image--bebe {
		object-position: center 25%;
	}

	.vip__card:hover .vip__card-image {
		transform: scale(1.05);
	}

	/* Ticket-style flip between the two concert headliners */
	.vip__flip {
		width: 100%;
		height: 100%;
		perspective: 1400px;
	}

	.vip__flip-inner {
		position: relative;
		width: 100%;
		height: 100%;
		transform-style: preserve-3d;
		transition: transform 0.85s cubic-bezier(0.45, 0, 0.15, 1);
	}

	.vip__flip.is-flipped .vip__flip-inner {
		transform: rotateX(-180deg);
	}

	.vip__flip-face {
		position: absolute;
		inset: 0;
		overflow: hidden;
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
	}

	.vip__flip-face--back {
		transform: rotateX(180deg);
	}

	.vip__flip-tag {
		position: absolute;
		left: 0.85rem;
		bottom: 0.85rem;
		padding: 0.35rem 0.7rem;
		background-color: rgba(0, 0, 0, 0.62);
		color: #fff;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		border-radius: 5px;
		backdrop-filter: blur(2px);
	}

	@media (prefers-reduced-motion: reduce) {
		.vip__flip-inner {
			transition: none;
		}
	}

	/* Tappable / hoverable headliner names that drive the flip */
	.vip__flip-name {
		font: inherit;
		color: inherit;
		text-transform: inherit;
		letter-spacing: inherit;
		background: none;
		border: 0;
		padding: 0;
		margin: 0;
		cursor: pointer;
		text-decoration: underline;
		text-decoration-style: dotted;
		text-decoration-thickness: 2px;
		text-underline-offset: 3px;
		transition: opacity 0.2s ease;
	}

	.vip__flip-name:hover,
	.vip__flip-name:focus-visible {
		text-decoration-style: solid;
		opacity: 0.82;
	}

	.vip__flip-name:focus-visible {
		outline: 2px solid rgba(255, 255, 255, 0.75);
		outline-offset: 2px;
		border-radius: 2px;
	}

	.vip__card-body {
		position: relative;
		padding: 2rem 1.65rem 1.85rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	/* Ticket-stub perforation: cream notches + dashed seam */
	.vip__notch {
		position: absolute;
		top: -14px;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background-color: var(--color-cream);
		pointer-events: none;
	}

	.vip__notch--left { left: -14px; }
	.vip__notch--right { right: -14px; }

	.vip__card-body::before {
		content: '';
		position: absolute;
		top: -1px;
		left: 18px;
		right: 18px;
		border-top: 2px dashed rgba(255, 255, 255, 0.45);
		pointer-events: none;
	}

	.vip__card-title {
		font-size: clamp(1.05rem, 1.5vw, 1.3rem);
		font-weight: 700;
		text-transform: uppercase;
		line-height: 1.2;
		margin: 0 0 0.7rem;
		letter-spacing: 0.01em;
		text-wrap: balance;
	}

	.vip__card-desc {
		font-size: 15px;
		line-height: 1.55;
		margin: 0 0 1.25rem;
		font-weight: 500;
		opacity: 0.95;
		text-wrap: pretty;
	}

	.vip__perks {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid rgba(255, 255, 255, 0.28);
		padding-top: 0.95rem;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	/* .vip__perks--standalone {
		margin-top: auto;
	} */

	.vip__perks li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.35;
	}

	.vip__perks li :global(.vip__check) {
		flex-shrink: 0;
		display: block;
		width: 16px;
		height: 15px;
		margin-top: 3px;
		color: #fff;
	}

	.vip__button {
		display: block;
		width: max-content;
		margin: 0 auto;
		padding: 1rem 2.75rem;
		background-color: var(--color-coral);
		color: #fff;
		border-radius: 8px;
		font-family: var(--font-family);
		font-size: 0.875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		text-decoration: none;
		transition: filter 0.3s;
	}

	.vip__button:hover {
		filter: brightness(1.1);
	}

	@media (max-width: 960px) {
		.vip__experiences {
			grid-template-columns: 1fr;
			max-width: 520px;
			margin-left: auto;
			margin-right: auto;
			gap: 1.5rem;
		}

		.vip__card-media {
			aspect-ratio: 16 / 9;
		}
	}

	@media (max-width: 768px) {
		.vip {
			padding: 3rem 1.5rem;
		}

		.vip__header {
			margin-bottom: 2rem;
		}

		.vip__intro {
			font-size: 14px;
		}

		.vip__card-body {
			padding: 1.75rem 1.4rem 1.6rem;
		}

		.vip__card-desc {
			font-size: 14px;
		}

		.vip__perks li {
			font-size: 14px;
		}

		.vip__perks li :global(.vip__check) {
			width: 14px;
			height: 13px;
		}

		.vip__button {
			font-size: 13px;
			padding: 0.875rem 2rem;
		}
	}

	@media (max-width: 480px) {
		.vip__heading {
			line-height: 1.1;
		}
	}
</style>

<script>
	const flips = document.querySelectorAll<HTMLElement>('[data-flip]');
	flips.forEach((el) => {
		let timer: ReturnType<typeof setInterval>;
		const start = () => {
			timer = setInterval(() => el.classList.toggle('is-flipped'), 15000);
		};
		const show = (toBack: boolean) => {
			el.classList.toggle('is-flipped', toBack);
			clearInterval(timer);
			start(); // restart the cycle so it waits a full interval after any interaction
		};
		start();

		const card = el.closest('.vip__card');
		card?.querySelectorAll<HTMLElement>('[data-flip-to]').forEach((btn) => {
			const toBack = btn.dataset.flipTo === 'back';
			const activate = () => show(toBack);
			btn.addEventListener('pointerenter', activate);
			btn.addEventListener('focus', activate);
			btn.addEventListener('click', activate);
		});
	});
</script>
