						<svg class="vip__check" width="36" height="33" viewBox="0 0 36 33" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M35.7713 0.7257C35.4102 0.1264 34.7143-0.1342 34.0446 0.0677 27.2035 2.1655 19.0559 12.8433 11.2432 23.8078 7.9277 18.2637 4.4152 16.4135 0.7846 18.3092 0.3316 18.5504 0.0427 18.9868 0.0034 19.495-0.0295 20.0097 0.1937 20.4918 0.6139 20.7979 3.2466 22.7067 5.9778 26.088 9.2276 31.4431 9.8185 32.4203 10.8493 33.0002 11.9982 33.0002H12.0507C13.2325 32.9806 14.283 32.3617 14.8607 31.3389 18.3797 25.0847 21.8331 19.6056 25.2602 14.8368 28.6938 10.068 32.1078 6.0093 35.5481 2.589 36.0536 2.0874 36.1455 1.3381 35.7713 0.7257Z" fill="#F15B5B"/></svg>
