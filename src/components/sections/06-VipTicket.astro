---
import photo from '../../assets/images/06-vip-ticket/bottles-of-wine.jpg';
import chefPhoto from '../../assets/images/10-dine-drink/chef-zakarian.jpg';
import loudLuxuryPhoto from '../../assets/images/06-vip-ticket/loud-luxury.jpg';

const check = `<svg class="vip__check" aria-hidden="true" width="36" height="33" viewBox="0 0 36 33" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M35.7713 0.7257C35.4102 0.1264 34.7143-0.1342 34.0446 0.0677 27.2035 2.1655 19.0559 12.8433 11.2432 23.8078 7.9277 18.2637 4.4152 16.4135 0.7846 18.3092 0.3316 18.5504 0.0427 18.9868 0.0034 19.495-0.0295 20.0097 0.1937 20.4918 0.6139 20.7979 3.2466 22.7067 5.9778 26.088 9.2276 31.4431 9.8185 32.4203 10.8493 33.0002 11.9982 33.0002H12.0507C13.2325 32.9806 14.283 32.3617 14.8607 31.3389 18.3797 25.0847 21.8331 19.6056 25.2602 14.8368 28.6938 10.068 32.1078 6.0093 35.5481 2.589 36.0536 2.0874 36.1455 1.3381 35.7713 0.7257Z" fill="currentColor"/></svg>`;
---

<section class="vip">
	<div class="vip__inner">
		<header class="vip__header">
			<p class="vip__eyebrow">Ticketed Experiences</p>
			<h2 class="vip__heading">Elevate Your Match Day Experience</h2>
			<p class="vip__intro">Take your watch party to the next level with exclusive ticketed experiences designed for comfort, energy, and unforgettable views of the match.</p>
		</header>

		<div class="vip__experiences">
			<article class="vip__card vip__card--blue">
				<div class="vip__card-media">
					<img src={chefPhoto.src} alt="Celebrity Chef Geoffrey Zakarian" width="500" height="375" class="vip__card-image vip__card-image--chef" loading="lazy" />
				</div>
				<div class="vip__card-body">
					<span class="vip__notch vip__notch--left" aria-hidden="true"></span>
					<span class="vip__notch vip__notch--right" aria-hidden="true"></span>
					<h3 class="vip__card-title">Culinary Experience with Celebrity Chef Geoffrey Zakarian</h3>
					<p class="vip__card-desc">Watch the match from an exclusive private terrace while enjoying a curated culinary experience by Celebrity Chef Geoffrey Zakarian.</p>
					<ul class="vip__perks">
						<li><Fragment set:html={check} />Unlimited food and drink pairings from 12 PM – 3 PM</li>
						<li><Fragment set:html={check} />Lounge seating, cocktail tables, and shaded areas</li>
						<li><Fragment set:html={check} />Live cooking demonstrations (pre-match)</li>
					</ul>
				</div>
			</article>

			<article class="vip__card vip__card--coral">
				<div class="vip__card-media">
					<img src={photo.src} alt="Bottles of wine on ice at a VIP event" width="500" height="375" class="vip__card-image" loading="lazy" />
				</div>
				<div class="vip__card-body">
					<span class="vip__notch vip__notch--left" aria-hidden="true"></span>
					<span class="vip__notch vip__notch--right" aria-hidden="true"></span>
					<h3 class="vip__card-title">Passport Lounge Watch Parties</h3>
					<p class="vip__card-desc">Explore three unique themed lounges across Downtown Burbank, each offering its own vibe for watching the match.</p>
					<ul class="vip__perks">
						<li><Fragment set:html={check} />Freedom to move between lounges throughout the event</li>
						<li><Fragment set:html={check} />Shaded seating and social spaces</li>
					</ul>
				</div>
			</article>

			<article class="vip__card vip__card--pink">
				<div class="vip__card-media">
					<img src={loudLuxuryPhoto.src} alt="Loud Luxury performing live" width="500" height="375" class="vip__card-image vip__card-image--loud-luxury" loading="lazy" />
				</div>
				<div class="vip__card-body">
					<span class="vip__notch vip__notch--left" aria-hidden="true"></span>
					<span class="vip__notch vip__notch--right" aria-hidden="true"></span>
					<h3 class="vip__card-title">Concert Experience Featuring Loud Luxury</h3>
					<ul class="vip__perks vip__perks--standalone">
						<li><Fragment set:html={check} />Enjoy a post-match live concert</li>
						<li><Fragment set:html={check} />Add on to your ticket purchase</li>
					</ul>
				</div>
			</article>
		</div>

		<a
			href="https://tickets.cbfproductions.com/e/los-angeles-world-cup-26-fan-zone-downtown-burbank?utm_source=fanzone-dtb&utm_medium=vip-cta&utm_campaign=worldcup26"
			target="_blank"
			rel="noopener noreferrer"
			class="vip__button"
		>
			Get Tickets
		</a>
	</div>
</section>

<style>
	.vip {
		background-color: var(--color-cream);
		padding: 5rem 2rem;
	}

	.vip__inner {
		max-width: 1180px;
		margin: 0 auto;
	}

	.vip__header {
		text-align: center;
		max-width: 720px;
		margin: 0 auto 3rem;
	}

	.vip__eyebrow {
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--color-coral);
		margin: 0 0 0.65rem;
	}

	.vip__heading {
		font-size: clamp(1.75rem, 4vw, 44px);
		font-weight: 700;
		text-transform: uppercase;
		color: var(--color-blue);
		line-height: 1.1;
		margin: 0 0 1rem;
		text-wrap: balance;
	}

	.vip__intro {
		font-size: clamp(1rem, 1.3vw, 17px);
		line-height: 1.65;
		color: var(--color-dark);
		margin: 0;
		text-wrap: pretty;
	}

	.vip__experiences {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.75rem;
		margin-bottom: 3rem;
	}

	.vip__card {
		display: flex;
		flex-direction: column;
		border-radius: 18px;
		overflow: hidden;
		color: #fff;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.vip__card:hover {
		transform: translateY(-4px);
		box-shadow: 0 18px 38px rgba(0, 0, 0, 0.16);
	}

	.vip__card--blue { background-color: var(--color-blue); }
	.vip__card--coral { background-color: var(--color-coral); }
	.vip__card--pink { background-color: var(--color-pink); }

	.vip__card-media {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background-color: rgba(0, 0, 0, 0.1);
	}

	.vip__card-image {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.vip__card-image--chef {
		object-position: center 30%;
	}

	.vip__card-image--loud-luxury {
		object-position: center 15%;
	}

	.vip__card:hover .vip__card-image {
		transform: scale(1.05);
	}

	.vip__card-body {
		position: relative;
		padding: 2rem 1.65rem 1.85rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	/* Ticket-stub perforation: cream notches + dashed seam */
	.vip__notch {
		position: absolute;
		top: -14px;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background-color: var(--color-cream);
		pointer-events: none;
	}

	.vip__notch--left { left: -14px; }
	.vip__notch--right { right: -14px; }

	.vip__card-body::before {
		content: '';
		position: absolute;
		top: -1px;
		left: 18px;
		right: 18px;
		border-top: 2px dashed rgba(255, 255, 255, 0.45);
		pointer-events: none;
	}

	.vip__card-title {
		font-size: clamp(1.05rem, 1.5vw, 1.3rem);
		font-weight: 700;
		text-transform: uppercase;
		line-height: 1.2;
		margin: 0 0 0.7rem;
		letter-spacing: 0.01em;
		text-wrap: balance;
	}

	.vip__card-desc {
		font-size: 15px;
		line-height: 1.55;
		margin: 0 0 1.25rem;
		font-weight: 500;
		opacity: 0.95;
		text-wrap: pretty;
	}

	.vip__perks {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid rgba(255, 255, 255, 0.28);
		padding-top: 0.95rem;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}

	/* .vip__perks--standalone {
		margin-top: auto;
	} */

	.vip__perks li {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.35;
	}

	.vip__check {
		flex-shrink: 0;
		display: block;
		width: 16px;
		height: 15px;
		margin-top: 3px;
		color: #fff;
	}

	.vip__button {
		display: block;
		width: max-content;
		margin: 0 auto;
		padding: 1rem 2.75rem;
		background-color: var(--color-coral);
		color: #fff;
		border-radius: 8px;
		font-family: var(--font-family);
		font-size: 0.875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		text-decoration: none;
		transition: filter 0.3s;
	}

	.vip__button:hover {
		filter: brightness(1.1);
	}

	@media (max-width: 960px) {
		.vip__experiences {
			grid-template-columns: 1fr;
			max-width: 520px;
			margin-left: auto;
			margin-right: auto;
			gap: 1.5rem;
		}

		.vip__card-media {
			aspect-ratio: 16 / 9;
		}
	}

	@media (max-width: 768px) {
		.vip {
			padding: 3rem 1.5rem;
		}

		.vip__header {
			margin-bottom: 2rem;
		}

		.vip__intro {
			font-size: 14px;
		}

		.vip__card-body {
			padding: 1.75rem 1.4rem 1.6rem;
		}

		.vip__card-desc {
			font-size: 14px;
		}

		.vip__perks li {
			font-size: 14px;
		}

		.vip__check {
			width: 14px;
			height: 13px;
		}

		.vip__button {
			font-size: 13px;
			padding: 0.875rem 2rem;
		}
	}

	@media (max-width: 480px) {
		.vip__heading {
			line-height: 1.1;
		}
	}
</style>
