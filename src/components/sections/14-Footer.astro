---

---

<!-- Newsletter Signup -->
<div id="footer_form" class="footer__form background--cover padding-y-m"
	style={`background-image: url('/images/newsletter-bg-scaled.jpg');`}>
	<div class="section__inner">
		<div class="gform_wrapper" id="gform_wrapper_6">
			<div class="gform_heading">
				<h3 class="gform_title">Join Our Newsletter</h3>
				<p class="gform_description">Sign up for our email newsletter to be the first to know about discounts, deals, and special events.</p>
			</div>
			<form action="https://dtnbur.us1.list-manage.com/subscribe/post?u=d39a40a7ee8f8f205b752e8bb&id=c16760089d"
				method="post" id="mc-embedded-subscribe-form" name="mc-embedded-subscribe-form" target="_blank" novalidate>
				<!-- Mailchimp bot signup prevention -->
				<div aria-hidden="true" style="position: absolute; left: -5000px;">
					<input type="text" name="b_d39a40a7ee8f8f205b752e8bb_c16760089d" tabindex="-1" value="" />
				</div>

				<div class="gform-body gform_body">
					<ul class="gform_fields">
						<!-- Name -->
						<li class="gfield">
							<label class="gfield_label" for="mce-FNAME">Name</label>
							<div class="ginput_container">
								<input name="FNAME" id="mce-FNAME" type="text" value="" placeholder="Name" />
							</div>
						</li>
						<!-- Email -->
						<li class="gfield">
							<label class="gfield_label" for="mce-EMAIL">Email</label>
							<div class="ginput_container">
								<input name="EMAIL" id="mce-EMAIL" type="email" value="" placeholder="Email" required />
							</div>
						</li>
						<!-- Phone -->
						<li class="gfield">
							<label class="gfield_label" for="mce-PHONE">Phone Number</label>
							<div class="ginput_container">
								<input name="PHONE" id="mce-PHONE" type="tel" value="" placeholder="Phone Number" />
							</div>
						</li>
						<!-- Zip Code -->
						<li class="gfield">
							<label class="gfield_label" for="mce-MMERGE3">Zip Code</label>
							<div class="ginput_container">
								<input name="MMERGE3" id="mce-MMERGE3" type="text" value="" placeholder="Zip Code" />
							</div>
						</li>
					</ul>
				</div>
				<div class="gform-footer gform_footer">
					<input type="submit" name="subscribe" class="gform_button button" value="Sign Up Today" />
				</div>
			</form>
		</div>
	</div>
</div>

<!-- Main Footer -->
<footer class="footer padding-y-m">
	<div class="footer__inner section__inner">
		<div class="footer__branding">
			<div class="footer__logo-wrapper">
				<img class="footer__logo" src="/logo/dtnbur_logo.png" alt="Downtown Burbank" />
			</div>
			<div class="footer__social-wrapper">
				<div class="footer__social-heading">Follow Us</div>
				<div class="footer__social">
					<a href="https://www.facebook.com/DowntownBurbank" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"><path fill="#fff" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
					</a>
					<a href="https://twitter.com/DowntownBUR" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" fill="#fff"/></svg>
					</a>
					<a href="https://instagram.com/downtownburbank" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"><path fill="#fff" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
					</a>
				</div>
			</div>
		</div>
		<div class="footer__nav footer__menu-wrapper">
			<ul id="menu-footer-nav" class="footer__menu">
				<li class="menu-item"><a href="https://dtnbur.com/shop/">Shop</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/dine/">Dine</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/explore/">Explore</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/broker/">Leasing &amp; Broker Info</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/about/">About</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/contact-us/">Contact Us</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/blog/">Blog</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/area-map/">Area Map</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/transportation/">Transportation</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/parking/">Parking &amp; Directions</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/directory/">Full Directory</a></li>
			</ul>
		</div>
	</div>

	<!-- Partner logos -->
	<div class="footer__inner section__inner footer__partners-row">
		<div class="footer__partners">
			<a href="https://www.burbankca.gov/" class="partner" target="_blank" rel="noopener noreferrer">
				<img src="/images/cityofburbank.png" alt="City of Burbank" loading="lazy" />
			</a>
			<a href="https://www.visitburbank.com/" class="partner" target="_blank" rel="noopener noreferrer">
				<img src="/images/visitburbank.png" alt="Visit Burbank" loading="lazy" />
			</a>
			<a href="https://www.burbankca.gov/" class="partner" target="_blank" rel="noopener noreferrer">
				<img src="/images/bur_seal-1.png" alt="City of Burbank Seal" loading="lazy" />
			</a>
		</div>
	</div>

	<!-- Copyright & legal -->
	<div class="footer__footnotes footer__inner section__inner">
		<div class="footer__copyright">
			<small>&copy; {new Date().getFullYear()} Downtown Burbank Partnership, Inc.<br/>A California nonprofit mutual benefit corporation.</small>
		</div>
		<div class="footer__legal-wrapper">
			<ul class="footer__menu footer__menu--legal">
				<li class="menu-item"><a rel="privacy-policy" href="https://dtnbur.com/privacy-policy/">Privacy Policy</a></li>
				<li class="menu-item"><a href="https://dtnbur.com/terms-and-conditions/">Terms &amp; Conditions</a></li>
			</ul>
		</div>
	</div>
</footer>

<style>
	/* ===== Newsletter Section ===== */
	.footer__form {
		background-size: cover;
		background-position: center;
		padding-top: 40px;
		padding-bottom: 40px;
	}

	.footer__form .section__inner {
		max-width: calc(950px + 2 * 30px);
		padding-left: 30px;
		padding-right: 30px;
		margin: 0 auto;
		height: 100%;
	}

	.gform_wrapper {
		display: block;
	}

	@media (min-width: 601px) {
		.gform_wrapper {
			display: flex;
			align-items: center;
		}
	}

	.gform_heading {
		color: #fff;
		padding: 40px 0;
	}

	@media (min-width: 601px) {
		.gform_heading {
			margin-top: 100px;
			padding: 0 40px 0 0;
			width: 55%;
		}
		.gform_heading > * {
			display: block;
			max-width: 375px;
		}
	}

	.gform_title {
		font-size: 2rem;
		font-weight: bold;
		margin-bottom: 0.5em;
	}

	.gform_description {
		font-size: 1rem;
		line-height: 1.5;
	}

	#mc-embedded-subscribe-form {
		background: #fff;
		border-radius: 8px;
		box-shadow: 1px 2px 8px -1px rgba(0, 0, 0, 0.2);
	}

	@media (min-width: 601px) {
		#mc-embedded-subscribe-form {
			max-width: 45%;
			width: 45%;
		}
	}

	.gform_fields {
		list-style: none;
		padding: 20px 50px 10px;
	}

	@media (max-width: 1000px) {
		.gform_fields {
			padding-left: 5vw;
			padding-right: 5vw;
		}
	}

	.gfield {
		margin-bottom: 10px;
	}

	.gfield_label {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.gfield input {
		width: 100%;
		border: none;
		border-bottom: 1px solid #1f2431;
		font-weight: normal;
		padding: 1rem 0;
		color: #4b4b4b;
		font-family: inherit;
		font-size: 0.875rem;
		outline: none;
		background: transparent;
	}

	.gfield input::placeholder {
		color: #999;
	}

	.gform_footer {
		display: flex;
		justify-content: flex-end;
		width: 100%;
	}

	.gform_footer input {
		display: flex;
		justify-content: center;
		background: #f15b5b;
		color: #fff;
		width: 100%;
		padding: 0.75rem;
		border: none;
		border-radius: 0;
		border-bottom-left-radius: 8px;
		border-bottom-right-radius: 8px;
		text-align: center;
		text-transform: uppercase;
		font-weight: bold;
		font-size: 1.5rem;
		font-family: inherit;
		box-shadow: 1px 2px 8px -1px rgba(0, 0, 0, 0.2);
		cursor: pointer;
		transition: filter 0.3s;
	}

	.gform_footer input:hover {
		filter: saturate(1.1);
	}

	@media (min-width: 601px) {
		.gform_footer input {
			max-width: 100%;
		}
	}

	/* ===== Main Footer ===== */
	.footer {
		background: #3c3c3c;
		padding-top: 40px;
		padding-bottom: 40px;
	}

	.footer a,
	.footer p,
	.footer small,
	.footer div {
		color: #fff;
	}

	.footer .section__inner {
		max-width: 1120px;
		padding-left: 15px;
		padding-right: 15px;
		margin-left: auto;
		margin-right: auto;
	}

	@media (min-width: 768px) {
		.footer .section__inner {
			padding-left: 30px;
			padding-right: 30px;
		}
	}

	.footer__inner {
		display: block;
	}

	@media (min-width: 961px) {
		.footer__inner:first-child {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
		}
	}

	/* Branding row */
	.footer__branding {
		display: flex;
		justify-content: space-between;
		margin-bottom: 20px;
		flex: 1 1 auto;
	}

	@media (min-width: 961px) {
		.footer__branding {
			margin-bottom: 0;
		}
	}

	.footer__logo {
		display: block;
		max-width: 180px;
		padding-bottom: 18px;
	}

	.footer__logo-wrapper {
		flex: 1 1 auto;
		margin-right: 60px;
	}

	@media (max-width: 1500px) {
		.footer__logo-wrapper { margin-right: 4vw; }
	}

	@media (max-width: 480px) {
		.footer__logo-wrapper { display: none; }
	}

	/* Social */
	.footer__social-wrapper {
		flex: 1 1 auto;
		min-width: 180px;
		max-width: 240px;
	}

	@media (max-width: 960px) {
		.footer__social-wrapper {
			min-width: calc((100% - 40px) / 3);
			max-width: calc((100% - 40px) / 3);
		}
	}

	@media (max-width: 480px) {
		.footer__social-wrapper { min-width: 100%; }
	}

	.footer__social-heading {
		margin-bottom: 1em;
	}

	@media (max-width: 480px) {
		.footer__social-heading { display: none; }
		.footer__social { margin: 0 auto; }
	}

	.footer__social {
		display: flex;
		justify-content: space-between;
		max-width: 150px;
	}

	.footer__social a {
		display: block;
	}

	.footer__social svg {
		width: 24px;
		height: 24px;
	}

	.footer__social svg path,
	.footer__social svg circle {
		fill: #fff;
	}

	/* Footer nav */
	.footer__menu-wrapper {
		min-width: 100%;
		max-width: 100%;
	}

	@media (min-width: 961px) {
		.footer__menu-wrapper {
			min-width: calc(0.45 * 950px + (100% - 950px) / 2);
			max-width: calc(0.45 * 950px + (100% - 950px) / 2);
		}
	}

	.footer__menu {
		list-style: none;
		column-gap: 40px;
	}

	#menu-footer-nav {
		column-count: 3;
	}

	@media (max-width: 480px) {
		#menu-footer-nav { column-count: 2; }
	}

	@media (max-width: 1350px) {
		.footer__menu { column-gap: 20px; }
	}

	.footer__nav a {
		font-size: 0.875rem;
	}

	@media (max-width: 480px) {
		.footer__nav { display: none; }
	}

	.footer__menu .menu-item {
		margin-bottom: 0.5em;
	}

	/* Partners */
	.footer__partners-row {
		display: flex;
		justify-content: flex-end;
		margin-top: 40px;
	}

	@media (max-width: 480px) {
		.footer__partners-row {
			justify-content: center;
		}
	}

	.footer__partners {
		display: flex;
		align-items: flex-end;
	}

	.footer__partners .partner {
		display: inline-block;
		width: calc((100% - 80px) / 3);
	}

	.footer__partners .partner:not(:first-of-type) {
		margin-left: 40px;
	}

	@media (max-width: 1350px) {
		.footer__partners .partner {
			width: calc((100% - 40px) / 3);
		}
		.footer__partners .partner:not(:first-of-type) {
			margin-left: 20px;
		}
	}

	@media (max-width: 480px) {
		.footer__partners .partner {
			width: calc(50% - 20px);
		}
	}

	.footer__partners .partner img {
		display: block;
		width: 100%;
		max-width: 150px;
		transition: filter 0.3s;
	}

	.footer__partners .partner:hover img {
		filter: brightness(200%);
	}

	/* Footnotes / Copyright */
	.footer__footnotes {
		margin-top: 35px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		position: relative;
		padding-top: 20px;
	}

	.footer__footnotes::before {
		content: '';
		display: block;
		height: 1px;
		width: calc(100% - 30px);
		background: #dde1e4;
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
	}

	.footer__footnotes a,
	.footer__footnotes p,
	.footer__footnotes small,
	.footer__footnotes div {
		font-size: 0.8125rem;
		line-height: 1.5;
	}

	.footer__menu--legal {
		list-style: none;
		display: flex;
		gap: 40px;
	}

	@media (max-width: 1350px) {
		.footer__footnotes {
			flex-direction: column;
			align-items: flex-start;
		}
		.footer__menu--legal {
			margin-top: 1rem;
		}
	}

	@media (max-width: 480px) {
		.footer__footnotes {
			text-align: center;
			align-items: center;
		}
	}
</style>
