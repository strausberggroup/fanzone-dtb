<script>
	function initBackArrow() {
		const btn = document.getElementById('back-arrow');
		const formSection = document.getElementById('footer_form');
		if (!btn || !formSection) return;

		let sourceEl: HTMLElement | null = null;

		function show() { btn.classList.add('visible'); }
		function hide() { btn.classList.remove('visible'); }

		// Track which anchor link brought the user to #footer_form
		document.querySelectorAll('a[href="#footer_form"]').forEach((link) => {
			link.addEventListener('click', () => {
				sourceEl = link as HTMLElement;
				show();
			});
		});

		// Scroll back to the link that brought them here
		btn.addEventListener('click', () => {
			hide();
			if (sourceEl) {
				sourceEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
				sourceEl = null;
			}
		});
	}

	document.addEventListener('astro:page-load', initBackArrow);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initBackArrow);
	} else {
		initBackArrow();
	}
</script>
