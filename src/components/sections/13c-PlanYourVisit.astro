---
type Bullet = { label: string; href?: string };
type Chapter = {
	href: string;
	title: string;
	desc: string;
	color: 'coral' | 'blue' | 'pink';
	bullets: Bullet[];
	cta: string;
};

const chapters: Chapter[] = [
	{
		href: '/info#info',
		title: 'Event Info',
		desc: 'Hours, parking, check-in, ticket access, schedule, and programming.',
		color: 'coral',
		bullets: [
			{ label: 'Parking', href: '/info#parking' },
			{ label: 'Check-In', href: '/info#check-in' },
			{ label: 'Ticket Access', href: '/info#access' },
			{ label: 'Game Schedule', href: '/info#games' },
		],
		cta: 'View Event Info',
	},
	{
		href: '/info#faqs',
		title: 'FAQs',
		desc: 'Common questions about the concert, food, hours, seating, and more.',
		color: 'blue',
		bullets: [
			{ label: 'Does my ticket include the concert?' },
			{ label: 'Which ticket should I choose?' },
			{ label: 'Where should I park?' },
		],
		cta: 'Read the FAQs',
	},
	{
		href: '/info#rules',
		title: 'Rules',
		desc: 'Event rules and prohibited items — please read before you arrive.',
		color: 'pink',
		bullets: [
			{ label: 'Refund &amp; weather policy' },
			{ label: 'Wristbands &amp; re-entry' },
			{ label: 'Prohibited items' },
		],
		cta: 'Read the Rules',
	},
];
---

<section class="plan-visit">
	<div class="plan-visit__inner">
		<p class="plan-visit__eyebrow">Know Before You Go</p>
		<h2 class="plan-visit__heading">Plan Your Visit</h2>
		<p class="plan-visit__intro">Everything you need to know before the gates open.</p>

		<div class="plan-visit__grid">
			{chapters.map(ch => (
				<article class={`plan-visit__card plan-visit__card--${ch.color}`}>
					<h3 class="plan-visit__title">{ch.title}</h3>
					<p class="plan-visit__desc">{ch.desc}</p>
					<ul class="plan-visit__bullets">
						{ch.bullets.map(b => (
							<li>
								{b.href
									? <a href={b.href} set:html={b.label}></a>
									: <span set:html={b.label}></span>
								}
							</li>
						))}
					</ul>
					<a href={ch.href} class="plan-visit__cta">
						{ch.cta}
						<span aria-hidden="true">→</span>
					</a>
				</article>
			))}
		</div>

		<a href="/info" class="plan-visit__btn">View Full Event Guide</a>
	</div>
</section>

<style>
	.plan-visit {
		background-color: var(--color-cream);
		padding: 5rem 2rem;
		text-align: center;
	}

	.plan-visit__inner {
		max-width: 1150px;
		margin: 0 auto;
	}

	.plan-visit__eyebrow {
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--color-coral);
		margin-bottom: 0.6rem;
	}

	.plan-visit__heading {
		font-size: clamp(1.75rem, 4vw, 40px);
		font-weight: 700;
		text-transform: uppercase;
		color: var(--color-dark);
		margin-bottom: 0.85rem;
		line-height: 1.05;
	}

	.plan-visit__intro {
		font-size: clamp(1rem, 1.4vw, 1.1rem);
		line-height: 1.6;
		color: #555;
		max-width: 620px;
		margin: 0 auto 2.75rem;
		text-wrap: pretty;
	}

	.plan-visit__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
		margin: 0 0 2.75rem;
		text-align: left;
	}

	.plan-visit__card {
		border-radius: 16px;
		padding: 2rem 1.85rem 1.85rem;
		display: flex;
		flex-direction: column;
		color: #fff;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.plan-visit__card:hover {
		transform: translateY(-3px);
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
	}

	.plan-visit__card--coral { background: var(--color-coral); }
	.plan-visit__card--blue { background: var(--color-blue); }
	.plan-visit__card--pink {
		background:var(--color-pink);
		color: #fff;
	}

	.plan-visit__title {
		font-size: clamp(1.5rem, 2.4vw, 1.85rem);
		font-weight: 700;
		text-transform: uppercase;
		line-height: 1;
		margin-bottom: 0.65rem;
	}

	.plan-visit__desc {
		font-size: 0.98rem;
		line-height: 1.55;
		margin-bottom: 1.15rem;
		text-wrap: pretty;
		opacity: 0.95;
	}

	.plan-visit__bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.3);
		padding-top: 0.85rem;
	}

	.plan-visit__bullets li {
		font-size: 0.95rem;
		line-height: 1.4;
		padding: 0.35rem 0;
		position: relative;
		padding-left: 1.1rem;
		font-weight: 700;
	}

	.plan-visit__bullets li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.7rem;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #fff;
	}

	.plan-visit__bullets a {
		color: #fff;
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s;
	}

	.plan-visit__bullets a:hover,
	.plan-visit__bullets a:focus-visible {
		border-bottom-color: #fff;
		outline: none;
	}

	.plan-visit__cta {
		margin-top: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #fff;
		text-decoration: none;
		padding-top: 0.25rem;
	}

	.plan-visit__cta span {
		transition: transform 0.2s;
		font-size: 1.1rem;
		line-height: 1;
	}

	.plan-visit__cta:hover span {
		transform: translateX(4px);
	}

	.plan-visit__btn {
		display: inline-block;
		padding: 1rem 2.5rem;
		background-color: var(--color-coral);
		color: #fff;
		border-radius: 8px;
		font-family: var(--font-family);
		font-size: 0.875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		text-decoration: none;
		transition: filter 0.3s;
	}

	.plan-visit__btn:hover {
		filter: brightness(1.1);
	}

	@media (max-width: 900px) {
		.plan-visit__grid {
			grid-template-columns: 1fr;
			max-width: 540px;
			margin-left: auto;
			margin-right: auto;
		}
	}

	@media (max-width: 768px) {
		.plan-visit { padding: 3rem 1.5rem; }
		.plan-visit__btn { font-size: 13px; }
	}
</style>
