---
import photo from '../../assets/images/07-get-involved/people-walking-outside-fair.jpg';
---

<section class="get-involved">
	<div class="get-involved__card">
		<div class="get-involved__image">
			<img src={photo.src} alt="People walking through an outdoor street fair with white tent canopies" width="400" />
		</div>
		<div class="get-involved__content">
			<h2 class="get-involved__heading">Get Involved in the Fan Zone</h2>
			<p class="get-involved__text">Interested in becoming a sponsor or vendor at this exciting Downtown Burbank Fan Zone event? Join us in bringing this high-energy experience to life and connect with thousands of attendees.</p>
			<a href="#" class="get-involved__button">Download Interest Form</a>
		</div>
	</div>
</section>

<style>
	.get-involved {
		background-color: var(--color-cream);
		padding: 5rem 2rem;
	}

	.get-involved__card {
		max-width: 990px;
		margin: 0 auto;
		background-color: var(--color-red);
		border-radius: 16px;
		display: flex;
		align-items: center;
		overflow: hidden;
		padding: 2.5rem;
		gap: 2.5rem;
	}

	.get-involved__image {
		flex-shrink: 0;
		width: clamp(200px, 35%, 340px);
	}

	.get-involved__image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
		display: block;
	}

	.get-involved__content {
		flex: 1;
	}

	.get-involved__heading {
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: 700;
		text-transform: uppercase;
		color: #fff;
		line-height: 1.1;
		margin-bottom: 0.6em;
	}

	.get-involved__text {
		font-size: 16px;
		line-height: 1.6;
		color: #fff;
		margin-bottom: 1.5em;
	}

	.get-involved__button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background-color: var(--color-blue);
		color: #fff;
		border-radius: 8px;
		font-family: var(--font-family);
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		transition: filter 0.3s;
	}

	.get-involved__button:hover {
		filter: brightness(1.15);
	}

	@media (max-width: 768px) {
		.get-involved__card {
			flex-direction: column;
			padding: 1.5rem;
		}

		.get-involved__image {
			width: 100%;
		}
	}
</style>
