---
import photo from '../../assets/images/07-get-involved/people-walking-outside-fair.jpg';
import cityOfBurbankLogo from '../../assets/images/07-get-involved/city-of-burbank.svg';
import visitBurbankLogo from '../../assets/images/07-get-involved/visit-burbank.svg';
import wbStudioTourLogo from '../../assets/images/07-get-involved/WB_StudioTour_Hollywood_LOGO_RGBDigital_horizontal_outlineShield_lightBkg.png';
---

<section class="get-involved">
	<div class="get-involved__card">
		<div class="get-involved__image">
			<img src={photo.src} alt="People walking through an outdoor street fair with white tent canopies" width="400" />
		</div>
		<div class="get-involved__content">
			<h2 class="get-involved__heading">Get Involved in the Los Angeles World Cup 26 Fan Zone at Downtown Burbank</h2>
			<p class="get-involved__text">Interested in becoming a sponsor or vendor at this exciting Los Angeles World Cup 26 Fan Zone at Downtown Burbank? Join us in bringing this high-energy experience to life and connect with thousands of attendees.</p>
			<a href="/images/DownTown-Burbank-Vendor-Flyer-World-Cup-FanZone.png" class="get-involved__button" aria-label="Download Interest Form" target="_blank">Download Interest Form</a>
		</div>
	</div>

	<div class="get-involved__sponsors">
		<h3 class="get-involved__sponsors-heading">City of Burbank Soccer Watch Party Sponsors</h3>
		<ul class="get-involved__sponsors-list">
			<li class="get-involved__sponsor">
				<img src={wbStudioTourLogo.src} alt="Warner Bros. Studio Tour Hollywood" loading="lazy" />
			</li>
			<li class="get-involved__sponsor">
				<img src={cityOfBurbankLogo.src} alt="City of Burbank" loading="lazy" />
			</li>
			<li class="get-involved__sponsor">
				<img src={visitBurbankLogo.src} class="vb" alt="Visit Burbank" loading="lazy" />
			</li>
		</ul>
	</div>
</section>

<style>
	.get-involved {
		background-color: var(--color-cream);
		padding: 5rem 2rem;
	}

	.get-involved__card {
		max-width: 1125px;
		margin: 0 auto;
		background-color: var(--color-red);
		border-radius: 16px;
		display: flex;
		align-items: center;
		overflow: hidden;
		padding: 2.5rem 4.75rem;
		gap: 2.5rem;
	}

	.get-involved__image {
		flex-shrink: 0;
		width: clamp(200px, 35%, 340px);
	}

	.get-involved__image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
		display: block;
	}

	.get-involved__content {
		flex: 1;
	}

	.get-involved__heading {
		font-size: clamp(1.75rem, 3.5vw, 40px);
		font-weight: 700;
		text-transform: uppercase;
		color: #fff;
		line-height: 1.1;
		margin-bottom: 1rem;
		text-wrap: pretty;
	}

	.get-involved__text {
		font-size: 16px;
		line-height: 1.6;
		color: #fff;
		margin-bottom: 1em;
		text-wrap: pretty;
	}

	.get-involved__button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background-color: var(--color-blue);
		color: #fff;
		border-radius: 8px;
		font-family: var(--font-family);
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		transition: filter 0.3s;
	}

	.get-involved__button:hover {
		filter: brightness(1.15);
	}

	.get-involved__sponsors {
		max-width: 925px;
		margin: 3.5rem auto 0;
		text-align: center;
	}

	.get-involved__sponsors-heading {
		font-size: clamp(1.125rem, 2vw, 1.5rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--color-dark);
		margin-top: 1rem;
	}

	.get-involved__sponsors-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		justify-content: center;
		align-items: center;
		flex-wrap: wrap;
		gap: 3rem;
	}

	.get-involved__sponsor {
		display: flex;
		align-items: center;
		justify-content: center;
		flex: 0 1 auto;
	}

	.get-involved__sponsor img {
		display: block;
		/* max-height: 70px; */
		width: auto;
		max-width: 220px;
		object-fit: contain;
	}
	.get-involved__sponsor img.vb {
		max-height: 60px;
		filter: brightness(0)

	}

	@media (max-width: 768px) {

		.get-involved{
			padding: 2rem 2rem 3rem;
		}
		.get-involved__card {
			flex-direction: column;
			padding: 1.5rem;
			gap: 1.5rem;
		}

		.get-involved__image {
			width: 100%;
		}
		.get-involved__image img {
			aspect-ratio: 3/2;
			object-fit: cover;
		}
		.get-involved__heading {
			margin-bottom: 0.75rem;
		}
		.get-involved__text {
			font-size: 14px;
		}
		.get-involved__button {
			font-size: 13px;
			padding: 0.75rem 1.75rem;
		}

		.get-involved__sponsors {
			margin-top: 2.5rem;
		}

		.get-involved__sponsors-heading {
			margin-bottom: 1.5rem;
		}

		.get-involved__sponsors-list {
			gap: 2rem 2.5rem;
		}

		.get-involved__sponsor img {
			max-height: 56px;
			max-width: 160px;
		}
	}
</style>
