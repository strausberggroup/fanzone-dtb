---
import photo from '../../assets/images/05-no-tickets/people-walk-outside.jpg';
---

<section class="no-tickets">
	<div class="no-tickets__inner">
		<div class="no-tickets__content">
			<h2 class="no-tickets__heading">No Tickets to the Stadium Games? No Problem!</h2>
			<p class="no-tickets__intro">The Los Angeles World Cup 26 Fan Zone at Downtown Burbank has you covered.</p>
			<ul class="no-tickets__list">
				<li>Live match viewings on large LED screens</li>
				<li>Food and drinks</li>
				<li>VIP offerings</li>
				<li>Family-friendly games</li>
				<li>Soccer merchandise</li>
				<li>Live entertainment</li>
			</ul>
			<p class="no-tickets__bold">The Downtown Burbank Fan Zone is a ticketed event, and all attendees must register online.</p>
			<p class="no-tickets__italic"><em>Registration opens soon and capacity is limited.</em></p>
			<a href="#footer_form" class="no-tickets__button">Sign Up for Newsletter to Be Notified</a>
		</div>
		<div class="no-tickets__image">
			<img src={photo.src} alt="Fans celebrating at a FIFA World Cup Fan Zone" width="570" />
		</div>
	</div>
</section>

<style>
	.no-tickets {
		background-color: var(--color-cream);
		padding: 5rem 2rem;
	}

	.no-tickets__inner {
		max-width: 1150px;
		margin: 0 auto;
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: clamp(2rem, 5vw, 4rem);
		flex-direction: row;
	}

	.no-tickets__content {

		max-width: 500px
	}

	.no-tickets__heading {
    font-size: clamp(2rem, 4vw, 45px);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-coral);
    line-height: normal;
    margin-bottom: 1rem;
    max-width: 475px;
	}

	.no-tickets__intro {
		font-size: 16px;
		line-height: 1.6;
		color: var(--color-dark);
		margin-bottom: 0.75em;
	}

	.no-tickets__list {
		font-size: 16px;
		line-height: 1.6;
		color: var(--color-dark);
		margin-bottom: 1em;
		padding-left: 1.5em;
	}

	/* .no-tickets__list li {
		margin-bottom: 0.25em;
	} */
	.no-tickets__list li::marker {
		font-size: 0.75em;
	}

	.no-tickets__bold {
		font-size: 17px;
		font-weight: 700;
		line-height: 1.1;
		color: var(--color-dark);
		margin-bottom: 1em;
	}

	.no-tickets__italic {
		font-size: 17px;
		line-height: 1.1;
		font-weight: 700;
		color: var(--color-dark);
		margin-bottom: 1.25em;
	}

	.no-tickets__button {
		display: inline-block;
		padding: 0.875rem 2rem;
		background-color: var(--color-coral);
		color: #fff;
		border-radius: 8px;
		font-family: var(--font-family);
		font-size: 0.8125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		transition: filter 0.3s;
	}

	.no-tickets__button:hover {
		filter: brightness(1.1);
	}



	.no-tickets__image img {
		width: 100%;
		height: auto;
		border-radius: 16px;
		max-width: 495px;
	}

	@media (max-width: 768px) {
		.no-tickets {
			padding: 3rem 2rem 1rem;
			}
			.no-tickets__inner {
				flex-direction: column-reverse;
			}
		}

		.no-tickets__image {
			width: 100%;
			max-width: 500px;
		}
	}
</style>
