---
import photo from '../../assets/images/11-stay-here/hotel-interior.jpg';
---

<section class="stay-here">
	<div class="stay-here__card">
		<canvas id="stay-here-dots" class="stay-here__canvas"></canvas>
		<div class="stay-here__image">
			<img src={photo.src} alt="Stylish hotel lobby with modern blue curved sofa and plants" width="900" height="400" />
		</div>

		<div class="stay-here__content">
			<h2 class="stay-here__heading">Stay Where the Action Is</h2>
			<p class="stay-here__text">Stay steps from the celebration at one of Burbank's<br />hotels and make a full weekend of it.</p>

			<form
				class="stay-here__booking"
				action="https://reservations.visitburbank.com/hotel/list/8215"
				method="get"
				target="_blank"
			>
				<div class="stay-here__field stay-here__field--date">
					<label class="sr-only" for="stay-checkin">Check In</label>
					<input
						type="date"
						id="stay-checkin"
						name="Search[checkInDate]"
						required
						aria-label="Check in date"
					/>
				</div>
				<div class="stay-here__field stay-here__field--date">
					<label class="sr-only" for="stay-checkout">Check Out</label>
					<input
						type="date"
						id="stay-checkout"
						name="Search[checkOutDate]"
						required
						aria-label="Check out date"
					/>
				</div>
				<div class="stay-here__field stay-here__field--select">
					<label class="sr-only" for="stay-adults">Adults</label>
					<select id="stay-adults" name="Search[numberOfAdults]" aria-label="Adults">
						<option value="1">One</option>
						<option value="2">Two</option>
						<option value="3">Three</option>
						<option value="4">Four</option>
					</select>
				</div>
				<div class="stay-here__field stay-here__field--select">
					<label class="sr-only" for="stay-children">Children</label>
					<select id="stay-children" name="Search[numberOfChildren]" aria-label="Children">
						<option value="0">None</option>
						<option value="1">One</option>
						<option value="2">Two</option>
						<option value="3">Three</option>
						<option value="4">Four</option>
						<option value="5">Five</option>
					</select>
				</div>
				<input type="hidden" name="Search[numberOfRooms]" value="1" />
				<input type="hidden" name="Search[hotelRegion]" value="m3288" />
				<button type="submit" class="stay-here__submit">
					Submit<span class="sr-only"> (opens in new window)</span>
				</button>
			</form>
		</div>
	</div>
</section>

<style>
	.stay-here {
		background-color: var(--color-cream);
		color: white;
		padding: 6rem 2rem 4rem;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.stay-here__card {
		max-width: 1100px;
		width: 100%;
		background-color: #5C8ECA;
		border-radius: 24px;
		overflow: hidden;
		text-align: center;
		padding: 3rem 0 1rem;
		position: relative;
	}

	.stay-here__canvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 55%;
		pointer-events: none;
	}

	.stay-here__image {
		position: relative;
		z-index: 1;
		padding: 3rem 3rem 0;
		max-width: 900px;
		margin: 0 auto;
	}

	.stay-here__image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
		display: block;
	}

	.stay-here__content {
		padding: 2.5rem 2rem 3.5rem;
	}

	.stay-here__heading {
		font-family: var(--font-family);
		font-size: clamp(1.8rem, 3.5vw, 40px);
		font-weight: 700;
		text-transform: uppercase;
		margin: 0 0 0.75rem;
	}

	.stay-here__text {
		font-family: var(--font-family);
		font-size: 17px;
		font-weight: 400;
		line-height: 1.6;
		margin: 0 0 1.5rem;
		opacity: 0.95;
	}

	.stay-here__booking {
		background-color: white;
		border-radius: 12px;
		padding: 1.5rem 1.75rem;
		display: flex;
		flex-wrap: wrap;
		align-items: flex-end;
		gap: 1.25rem;
		max-width: 900px;
		margin: 1.5rem auto 0;
		text-align: left;
		box-shadow: 0 6px 24px rgba(0, 0, 0, 0.08);
	}

	.stay-here__field {
		flex: 1 1 140px;
		min-width: 0;
		position: relative;
	}

	.stay-here__field input,
	.stay-here__field select {
		width: 100%;
		font-family: var(--font-family);
		font-size: 16px;
		color: #2b2b2b;
		background: transparent;
		border: 0;
		border-bottom: 1px solid #1a1a1a;
		border-radius: 0;
		padding: 0.5rem 0;
		box-sizing: border-box;
		min-height: 2.25rem;
	}

	.stay-here__field select {
		appearance: none;
		-webkit-appearance: none;
		-moz-appearance: none;
	}

	.stay-here__field input[type="date"] {
		appearance: none;
		-webkit-appearance: none;
		display: block;
		min-height: 2.25rem;
		line-height: 1.25;
	}

	.stay-here__field input[type="date"]::-webkit-calendar-picker-indicator {
		cursor: pointer;
		opacity: 0.6;
		filter: invert(0.2);
	}

	.stay-here__field input[type="date"]::-webkit-calendar-picker-indicator:hover {
		opacity: 1;
	}

	.stay-here__field input[type="date"]::-webkit-date-and-time-value {
		text-align: left;
	}

	.stay-here__field input::placeholder {
		color: #b0b0b0;
		opacity: 1;
	}

	.stay-here__field input:focus,
	.stay-here__field select:focus {
		outline: none;
		border-bottom-color: var(--color-coral);
	}

	.stay-here__field--select {
		flex: 1 1 100px;
	}

	.stay-here__field--select::after {
		content: "";
		position: absolute;
		right: 0.25rem;
		top: 50%;
		width: 10px;
		height: 10px;
		border-right: 2px solid #2b2b2b;
		border-bottom: 2px solid #2b2b2b;
		transform: translateY(-75%) rotate(45deg);
		pointer-events: none;
	}

	.stay-here__field--select select {
		padding-right: 1.5rem;
		cursor: pointer;
	}

	.stay-here__submit {
		flex: 0 0 auto;
		background-color: var(--color-coral);
		color: white;
		font-family: var(--font-family);
		font-size: 0.85rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.85rem 2rem;
		border: 0;
		border-radius: 4px;
		cursor: pointer;
		transition: filter 0.3s;
		align-self: flex-end;
	}

	.stay-here__submit:hover {
		filter: brightness(1.1);
	}

	@media (max-width: 768px) {
		.stay-here {
			padding: 0;
		}
		.stay-here__card {
			border-radius: 0;;
		}
		.stay-here__canvas {
			max-height: 200px;
		}

		.stay-here__image {
			padding: 1.5rem 1.5rem 0;
		}

		.stay-here__content {
			padding: 2rem 1.5rem 2.5rem;
			text-align: left;
		}
		.stay-here__text {
			font-size: 14px;
		}
		.stay-here__text br{
			display: none;
		}
		.stay-here__booking {
			padding: 1.25rem 1.25rem 1.5rem;
			gap: 1rem;
			flex-direction: column;
			align-items: stretch;
		}
		.stay-here__field {
			flex: 1 1 auto;
		}
		.stay-here__submit {
			font-size: 13px;
			padding: 0.85rem 1.75rem;
			width: 100%;
		}

	}
</style>

<script>
	function initStayHereDots() {
		const canvas = document.getElementById('stay-here-dots') as HTMLCanvasElement;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const BG = '#5C8ECA';
		const DOT_COLOR = '#4E7AB8';
		const RING_COLOR = '#7AAEE0';
		const DOT_RADIUS = 5;
		const RING_THICKNESS = 3;
		const SPACING = 30;

		let cols = 0;
		let rows = 0;
		let animId: number;

		function resize() {
			const dpr = window.devicePixelRatio || 1;
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;
			canvas.width = w * dpr;
			canvas.height = h * dpr;
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
			cols = Math.ceil(w / SPACING) + 1;
			rows = Math.ceil(h / SPACING) + 1;
		}

		interface Pulse {
			cx: number;
			cy: number;
			birth: number;
			duration: number;
			reach: number;
		}

		const pulses: Pulse[] = [];
		const PULSE_INTERVAL = 6000;
		const PULSE_DURATION = 10000;
		const PULSE_REACH = 400;
		let lastPulseTime = -PULSE_INTERVAL;

		function spawnPulse(time: number) {
			// Bias pulse centers toward the visible edges (not behind the centered image)
			const edge = Math.random();
			let cx: number, cy: number;
			if (edge < 0.35) {
				// Left strip
				cx = Math.random() * 0.2;
				cy = Math.random();
			} else if (edge < 0.7) {
				// Right strip
				cx = 0.8 + Math.random() * 0.2;
				cy = Math.random();
			} else {
				// Top strip
				cx = 0.1 + Math.random() * 0.8;
				cy = Math.random() * 0.25;
			}
			pulses.push({
				cx,
				cy,
				birth: time,
				duration: PULSE_DURATION + Math.random() * 1500,
				reach: PULSE_REACH + Math.random() * 100,
			});
			while (pulses.length > 4) {
				pulses.shift();
			}
		}

		function draw(time: number) {
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;

			ctx!.fillStyle = BG;
			ctx!.fillRect(0, 0, w, h);

			if (time - lastPulseTime > PULSE_INTERVAL) {
				spawnPulse(time);
				lastPulseTime = time;
			}

			const offsetX = ((w % SPACING) / 2);
			const offsetY = ((h % SPACING) / 2);

			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					const x = offsetX + c * SPACING;
					const y = offsetY + r * SPACING;

					let bestAlpha = 0;
					let bestScale = 1;

					for (const p of pulses) {
						const age = time - p.birth;
						if (age < 0 || age > p.duration) continue;

						const pcx = p.cx * w;
						const pcy = p.cy * h;
						const dist = Math.sqrt((x - pcx) ** 2 + (y - pcy) ** 2);

						if (dist > p.reach) continue;

						const proximity = 1 - dist / p.reach;
						const progress = age / p.duration;
						const breathe = Math.sin(progress * Math.PI);

						const alpha = proximity * breathe;
						if (alpha > bestAlpha) {
							bestAlpha = alpha;
							bestScale = 1 + 0.7 * alpha;
						}
					}

					if (bestAlpha > 0.05) {
						const dotR = DOT_RADIUS * bestScale;
						const ringR = dotR + RING_THICKNESS * bestAlpha;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR + (ringR - dotR) / 2, 0, Math.PI * 2);
						ctx!.strokeStyle = RING_COLOR;
						ctx!.globalAlpha = bestAlpha;
						ctx!.lineWidth = ringR - dotR;
						ctx!.stroke();
						ctx!.globalAlpha = 1;

						ctx!.beginPath();
						ctx!.arc(x, y, dotR, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					} else {
						ctx!.beginPath();
						ctx!.arc(x, y, DOT_RADIUS, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					}
				}
			}

			lastDrawTime = time;
			animId = requestAnimationFrame(draw);
		}

		let lastDrawTime = 0;
		const ro = new ResizeObserver(() => {
			resize();
			draw(lastDrawTime);
		});
		ro.observe(canvas);

		resize();

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReducedMotion) {
			draw(0);
			cancelAnimationFrame(animId!);
		} else {
			let isVisible = false;
			const io = new IntersectionObserver(([entry]) => {
				isVisible = entry.isIntersecting;
				if (isVisible) {
					animId = requestAnimationFrame(draw);
				} else {
					cancelAnimationFrame(animId);
				}
			}, { threshold: 0 });
			io.observe(canvas.closest('.stay-here')!);
		}
	}

	document.addEventListener('astro:page-load', initStayHereDots);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initStayHereDots);
	} else {
		initStayHereDots();
	}
</script>
