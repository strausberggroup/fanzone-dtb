<style>
	.be-part {
		background-color: var(--color-cream);
		padding: 4rem 2rem;
		display: flex;
		justify-content: center;
	}

	.be-part__card {
		max-width: 986px;
		width: 100%;
		background-color: #5C8ECA;
		border-radius: 24px;
		color: white;
		text-align: center;
		padding: 3rem 2rem 3.5rem;
	}

	.be-part__icons {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.be-part__icons a {
		display: flex;
		align-items: center;
		justify-content: center;
		transition: opacity 0.3s;
	}

	.be-part__icons a:hover {
		opacity: 0.8;
	}

	.be-part__heading {
		font-family: var(--font-family);
		font-size: clamp(1.8rem, 3.5vw, 2.8rem);
		font-weight: 700;
		text-transform: uppercase;
		color: var(--color-gold);
		margin: 0 0 0.75rem;
		font-style: italic;
	}

	.be-part__text {
		font-family: var(--font-family);
		font-size: clamp(0.95rem, 1.3vw, 1.1rem);
		font-weight: 400;
		margin: 0 0 1.25rem;
	}

	.be-part__list {
		list-style: disc;
		display: inline-block;
		text-align: left;
		font-family: var(--font-family);
		font-size: clamp(0.95rem, 1.3vw, 1.1rem);
		font-weight: 400;
		line-height: 1.8;
		margin: 0;
		padding-left: 1.25rem;
	}
</style>
