---
import logoImg from '../../assets/images/02-hero/la-wc26-fanzone-dtb.png';
import heroPhoto from '../../assets/images/02-hero/hero.jpg';
---
<div class="buffer">
</div>
<section class="hero">
	<canvas id="hero-dots" class="hero__canvas"></canvas>
	<div class="hero__inner">
		<div class="hero__left">
			<img src={logoImg.src} alt="Los Angeles World Cup 26 Fan Zone at Downtown Burbank" class="hero__logo" width="620" />
			<p class="hero__dates">July 18 | 12pm - 8pm<br />July 19 | 10am - 6pm</p>
			<a
				href="https://tickets.cbfproductions.com/e/los-angeles-world-cup-26-fan-zone-downtown-burbank?utm_source=fanzone-dtb&utm_medium=hero-cta&utm_campaign=worldcup26"
				target="_blank"
				rel="noopener noreferrer"
				class="hero__cta"
			>
				Get Tickets
			</a>
		</div>
		<div class="hero__right">
			<img src={heroPhoto.src} alt="Downtown Burbank street fair crowd on Olive Avenue" class="hero__photo" width="570" />
		</div>
	</div>
</section>

<script>
	function initHeroDots() {
		const canvas = document.getElementById('hero-dots') as HTMLCanvasElement;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const BG = '#FF5252';
		const DOT_COLOR = '#f63d59';
		const RING_COLOR = '#fb9765';
		const DOT_RADIUS = 10;
		const RING_THICKNESS = 6;
		const SPACING = 60; // dot center-to-center (20px dot + 40px gap)

		let cols = 0;
		let rows = 0;
		let animTime = 0;
		let animId: number;

		function resize() {
			const section = canvas.parentElement!;
			const dpr = window.devicePixelRatio || 1;
			const w = section.offsetWidth;
			const h = section.offsetHeight;
			canvas.width = w * dpr;
			canvas.height = h * dpr;
			canvas.style.width = w + 'px';
			canvas.style.height = h + 'px';
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
			cols = Math.ceil(w / SPACING) + 1;
			rows = Math.ceil(h / SPACING) + 1;
		}

		// Pulse system: 2-3 stationary clusters that slowly breathe in and out
		interface Pulse {
			cx: number; // center x (0-1 normalized)
			cy: number; // center y (0-1 normalized)
			birth: number; // time when pulse started
			duration: number; // total pulse lifetime in ms
			reach: number; // how far the effect reaches in pixels
		}

		const pulses: Pulse[] = [];
		const PULSE_INTERVAL = 3000; // ms between new pulses
		const PULSE_DURATION = 4500; // slow breathe in/out
		const PULSE_REACH = 350; // radius of affected area
		let lastPulseTime = -PULSE_INTERVAL;

		function spawnPulse(time: number) {
			pulses.push({
				cx: 0.1 + Math.random() * 0.8,
				cy: 0.1 + Math.random() * 0.8,
				birth: time,
				duration: PULSE_DURATION + Math.random() * 1500,
				reach: PULSE_REACH + Math.random() * 100,
			});
			// Keep only recent pulses
			while (pulses.length > 4) {
				pulses.shift();
			}
		}

		function draw(time: number) {
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;

			ctx!.fillStyle = BG;
			ctx!.fillRect(0, 0, w, h);

			// Spawn new pulses at intervals
			if (time - lastPulseTime > PULSE_INTERVAL) {
				spawnPulse(time);
				lastPulseTime = time;
			}

			// Offset to center the grid
			const offsetX = ((w % SPACING) / 2);
			const offsetY = ((h % SPACING) / 2);

			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					const x = offsetX + c * SPACING;
					const y = offsetY + r * SPACING;

					// Find max effect from all active pulses
					let bestAlpha = 0;
					let bestScale = 1;

					for (const p of pulses) {
						const age = time - p.birth;
						if (age < 0 || age > p.duration) continue;

						const pcx = p.cx * w;
						const pcy = p.cy * h;
						const dist = Math.sqrt((x - pcx) ** 2 + (y - pcy) ** 2);

						if (dist > p.reach) continue;

						// How close to pulse center (1 = at center, 0 = at edge)
						const proximity = 1 - dist / p.reach;

						// Slow sine breathe: ramps up then back down
						const progress = age / p.duration;
						const breathe = Math.sin(progress * Math.PI);

						// Linear proximity (not squared) so more dots are visibly affected
						const alpha = proximity * breathe;
						if (alpha > bestAlpha) {
							bestAlpha = alpha;
							bestScale = 1 + 0.6 * alpha;
						}
					}

					if (bestAlpha > 0.05) {
						const dotR = DOT_RADIUS * bestScale;
						const ringR = dotR + RING_THICKNESS * bestAlpha;

						// Draw ring
						ctx!.beginPath();
						ctx!.arc(x, y, dotR + (ringR - dotR) / 2, 0, Math.PI * 2);
						ctx!.strokeStyle = RING_COLOR;
						ctx!.globalAlpha = bestAlpha;
						ctx!.lineWidth = ringR - dotR;
						ctx!.stroke();
						ctx!.globalAlpha = 1;

						// Draw center dot
						ctx!.beginPath();
						ctx!.arc(x, y, dotR, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					} else {
						// Plain dot
						ctx!.beginPath();
						ctx!.arc(x, y, DOT_RADIUS, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					}
				}
			}

			lastDrawTime = time;
			animId = requestAnimationFrame(draw);
		}

		let lastDrawTime = 0;

		// Use ResizeObserver so canvas resizes when section grows (e.g. after images load)
		const section = canvas.parentElement!;
		const ro = new ResizeObserver(() => {
			resize();
			draw(lastDrawTime);
		});
		ro.observe(section);

		resize();

		// Respect reduced motion preference
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReducedMotion) {
			draw(0);
			cancelAnimationFrame(animId!);
		} else {
			// Only animate when visible
			let isVisible = false;
			const io = new IntersectionObserver(([entry]) => {
				isVisible = entry.isIntersecting;
				if (isVisible) {
					animId = requestAnimationFrame(draw);
				} else {
					cancelAnimationFrame(animId);
				}
			}, { threshold: 0 });
			io.observe(section);
		}
	}

	// Run on page load and after view transitions
	document.addEventListener('astro:page-load', initHeroDots);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initHeroDots);
	} else {
		initHeroDots();
	}
</script>

<style>
	.buffer {
		height: 90px;
		background-color: var(--color-coral);
	}
	.hero {
		background-color: #FF5252;
		padding: 3rem 2rem;
		position: relative;
		overflow: hidden;
	}

	.hero__canvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.hero__inner {
		max-width: 1250px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		padding: 2rem 0 1rem;
		position: relative;
		z-index: 1;
	}

	.hero__left {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero__logo {
		width: 100%;
		max-width: 620px;
		height: auto;
	}

	.hero__dates {
		color: white;
		font-family: var(--font-family);
		font-size: 40px;
		font-weight: 700;
		margin-top: 1rem;
		padding-left: 0.25em;
	}

	.hero__cta {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 1rem 2.5rem;
		background-color: white;
		color: var(--color-coral);
		border-radius: 8px;
		font-family: var(--font-family);
		font-size: 1.125rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		transition: transform 0.2s, filter 0.2s;
	}

	.hero__cta:hover {
		transform: translateY(-2px);
		filter: brightness(1.05);
	}

	.hero__right {
		flex-shrink: 0;
		width: 570px;
	}

	.hero__photo {
		width: 100%;
		height: auto;
		border-radius: 30px;
	}

	/* Responsive */
	@media (max-width: 960px) {

		.buffer {
			height: 75px;
		}
		.hero__inner {
			flex-direction: column;
			text-align: center;
			padding-top: 0;
		}

		.hero__left {
			align-items: center;
		}

		.hero__right {
			width: 100%;
			max-width: 570px;
		}

		.hero__dates {
			font-size: 28px;
			padding-left: 0;
		}

		.hero__cta {
			font-size: 1rem;
			padding: 0.875rem 2rem;
		}
	}
</style>
