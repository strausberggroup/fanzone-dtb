---
import logoImg from '../../assets/images/02-hero/la-wc26-fanzone-dtb.png';
import heroPhoto from '../../assets/images/02-hero/hero.jpg';
---
<div class="buffer">
</div>
<section class="hero">
	<canvas id="hero-dots" class="hero__canvas"></canvas>
	<div class="hero__inner">
		<div class="hero__left">
			<img src={logoImg.src} alt="Los Angeles World Cup 26 Fan Zone at Downtown Burbank" class="hero__logo" width="620" />
			<p class="hero__dates">July 18 &amp; 19</p>
		</div>
		<div class="hero__right">
			<img src={heroPhoto.src} alt="Downtown Burbank street fair crowd on Olive Avenue" class="hero__photo" width="570" />
		</div>
	</div>
</section>

<script>
	function initHeroDots() {
		const canvas = document.getElementById('hero-dots') as HTMLCanvasElement;
		if (!canvas) return;
		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const BG = '#FF5252';
		const DOT_COLOR = '#f63d59';
		const RING_COLOR = '#fb9765';
		const DOT_RADIUS = 10;
		const RING_THICKNESS = 5;
		const SPACING = 60; // dot center-to-center (20px dot + 40px gap)

		let cols = 0;
		let rows = 0;
		let animTime = 0;
		let animId: number;

		function resize() {
			const section = canvas.parentElement!;
			const dpr = window.devicePixelRatio || 1;
			const w = section.offsetWidth;
			const h = section.offsetHeight;
			canvas.width = w * dpr;
			canvas.height = h * dpr;
			canvas.style.width = w + 'px';
			canvas.style.height = h + 'px';
			ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
			cols = Math.ceil(w / SPACING) + 1;
			rows = Math.ceil(h / SPACING) + 1;
		}

		function draw(time: number) {
			const w = canvas.clientWidth;
			const h = canvas.clientHeight;

			ctx!.fillStyle = BG;
			ctx!.fillRect(0, 0, w, h);

			// Stadium wave: sweeps left-to-right and wraps around
			const waveSpeed = 0.08; // pixels per ms
			const waveWidth = 250; // width of the wave band
			// Total travel includes the full width plus extra so it wraps smoothly
			const totalTravel = w + waveWidth;
			const elapsed = time % (totalTravel / waveSpeed);
			const waveFront = elapsed * waveSpeed - waveWidth;

			// Offset to center the grid
			const offsetX = ((w % SPACING) / 2);
			const offsetY = ((h % SPACING) / 2);

			for (let r = 0; r < rows; r++) {
				for (let c = 0; c < cols; c++) {
					const x = offsetX + c * SPACING;
					const y = offsetY + r * SPACING;

					// Horizontal distance from wave front
					const wavePos = x - waveFront;
					const inWave = wavePos > 0 && wavePos < waveWidth;

					// Smooth envelope within the wave band
					let ringAlpha = 0;
					let scale = 1;
					if (inWave) {
						// Bell curve within the wave band
						const t = wavePos / waveWidth; // 0 to 1
						ringAlpha = Math.sin(t * Math.PI);
						scale = 1 + 0.3 * ringAlpha;
					}

					if (inWave && ringAlpha > 0.05) {
						const dotR = DOT_RADIUS * scale;
						const ringR = dotR + RING_THICKNESS * ringAlpha;

						// Draw ring (thick stroke centered on the edge of the dot)
						ctx!.beginPath();
						ctx!.arc(x, y, dotR + (ringR - dotR) / 2, 0, Math.PI * 2);
						ctx!.strokeStyle = RING_COLOR;
						ctx!.globalAlpha = ringAlpha;
						ctx!.lineWidth = ringR - dotR;
						ctx!.stroke();
						ctx!.globalAlpha = 1;

						// Draw center dot flush with inner edge of ring
						ctx!.beginPath();
						ctx!.arc(x, y, dotR, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					} else {
						// Plain dot
						ctx!.beginPath();
						ctx!.arc(x, y, DOT_RADIUS, 0, Math.PI * 2);
						ctx!.fillStyle = DOT_COLOR;
						ctx!.fill();
					}
				}
			}

			animId = requestAnimationFrame(draw);
		}

		resize();
		window.addEventListener('resize', resize);

		// Respect reduced motion preference
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (prefersReducedMotion) {
			draw(0);
			cancelAnimationFrame(animId!);
		} else {
			animId = requestAnimationFrame(draw);
		}
	}

	// Run on page load and after view transitions
	document.addEventListener('astro:page-load', initHeroDots);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initHeroDots);
	} else {
		initHeroDots();
	}
</script>

<style>
	.buffer {
		height: 90px;
		background-color: var(--color-coral);
	}
	.hero {
		background-color: #FF5252;
		padding: 3rem 2rem;
		position: relative;
		overflow: hidden;
	}

	.hero__canvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.hero__inner {
		max-width: 1250px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		padding: 2rem 0 1rem;
		position: relative;
		z-index: 1;
	}

	.hero__left {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero__logo {
		width: 100%;
		max-width: 620px;
		height: auto;
	}

	.hero__dates {
		color: white;
		font-family: var(--font-family);
		font-size: 40px;
		font-weight: 700;
		margin-top: 1rem;
		padding-left: 0.25em;
	}

	.hero__right {
		flex-shrink: 0;
		width: 570px;
	}

	.hero__photo {
		width: 100%;
		height: auto;
		border-radius: 30px;
	}

	/* Responsive */
	@media (max-width: 960px) {
		.hero__inner {
			flex-direction: column;
			text-align: center;
		}

		.hero__left {
			align-items: center;
		}

		.hero__right {
			width: 100%;
			max-width: 570px;
		}

		.hero__dates {
			font-size: 28px;
			padding-left: 0;
		}
	}
</style>
